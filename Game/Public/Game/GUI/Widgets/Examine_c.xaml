                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Source='h98a4ccfbg20f4g4294g9bf7g624c95711539',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SectionHeaderStyle}"/>
                                                            <ContentControl Content="{Binding .}" ContentTemplate="{StaticResource ResistancesTemplate}"/>
                                                        </StackPanel>
                                                    </ls:LSListBoxItem>

                                                </ls:LSListBox>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <!--Template for characters-->

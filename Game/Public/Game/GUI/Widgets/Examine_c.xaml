<ls:UIWidget x:Name="Examine_c"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ls="clr-namespace:ls;assembly=SharedGUI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignWidth="3840" d:DesignHeight="2160"
             ls:UIWidget.Focusable="False"
             ls:UIWidget.ContextName="Examine" d:DataContext="{d:DesignInstance {x:Type ls:DCExamine}, IsDesignTimeCreatable=True}"
             ls:UIWidget.SoundID="UI_HUD_Examine">

    <ls:UIWidget.Resources>
        <ResourceDictionary>
            <Style x:Key="CollapsableTextBlock" TargetType="TextBlock">
                <Style.Triggers>
                    <Trigger Property="Text" Value="">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StatTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                <Setter Property="FontSize" Value="{DynamicResource DefaultFontSize}"/>
            </Style>

            <Style x:Key="ConditionTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                <Setter Property="FontSize" Value="{DynamicResource BigFontSize}"/>
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource LS_SecondaryColor}"/>
                <Setter Property="FontSize" Value="{DynamicResource BigFontSize}"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,0,0"/>
            </Style>

            <Style x:Key="VerticalControllerExamineListBoxStyle" TargetType="ls:LSListBox" BasedOn="{StaticResource {x:Type ls:LSListBox}}">
                <Setter Property="Template" Value="{StaticResource ScrolllessListBox}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="ActionPrevEvent" Value="UIUp"/>
                <Setter Property="ActionNextEvent" Value="UIDown"/>
                <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue"/>
                <Setter Property="AutoScrollSelectedIntoView" Value="True"/>
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Itemsource.Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ExamineItemsStyle" TargetType="ls:LSListBoxItem"  BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Focusable" Value="True" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Magenta" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <DataTemplate x:Key="ApprovalDataTemplate">
                <Grid Background="Transparent"  HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Character.Name}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Rating, Converter={StaticResource ApprovalRatingToStringConverter}}"/>

                    <ContentControl ToolTip="{StaticResource ManagedTooltip}" ContentTemplate="{StaticResource ElementInfoHolder}"
                                    Content="{Binding }" Focusable="False" ToolTipService.Placement="Left"/>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="StatBarDataTemplate">
                <Grid Background="Transparent">
                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Name}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Value}"/>

                    <ContentControl ToolTip="{StaticResource ManagedTooltip}" ContentTemplate="{StaticResource ElementInfoHolder}"
                                    Content="{Binding }" Focusable="False" ToolTipService.Placement="Left"/>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="BonusBarDataTemplate">
                <Grid Background="Transparent">
                    <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Name}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Value, StringFormat={}{0:+#;-#;-}}"/>

                    <ContentControl ToolTip="{StaticResource ManagedTooltip}" ContentTemplate="{StaticResource ElementInfoHolder}"
                                    Content="{Binding }" Focusable="False" ToolTipService.Placement="Left"/>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="ConditionBarDataTemplate">
                <Grid Background="Transparent">
                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/frame_listItemCondition.png" Stretch="None"/>
                    <Image x:Name="highlight" Visibility="Hidden" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/selector_listItemCondition.png" Stretch="None"/>

                    <ContentControl ToolTip="{StaticResource ManagedTooltip}" ContentTemplate="{StaticResource StatusTemplate}" Height="97" 
                                    HorizontalAlignment="Left" Margin="8,0,0,11" Content="{Binding }" Focusable="False"
                                    ToolTipService.Placement="Left"/>

                    <TextBlock Text="{Binding Name}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="120,4,0,0" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource BigFontSize}"/>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:LSListBoxItem}}, Path=IsSelected}" Value="True">
                        <Setter Property="Visibility" Value="Visible" TargetName="highlight"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <DataTemplate x:Key="PassiveBarDataTemplate">
                <ls:LSListBox Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                    <ls:LSListBoxItem x:Name="MainPassive" ToolTip="{StaticResource ManagedTooltip}">
                        <Grid>
                            <Image x:Name="Frame" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_frame_listitem_resistance.png" Stretch="None"/>
                            <Image x:Name="Highlight" Visibility="Hidden" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_selector_listitem_resistance.png" Stretch="None"/>

                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Icon" Fill="{Binding Icon}" Width="58" Height="58" Margin="24,0"/>
                                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" Style="{StaticResource StatTextBlockStyle}" Text="{Binding Name}"/>
                            </StackPanel>
                        </Grid>
                    </ls:LSListBoxItem>

                    <ls:LSListBoxItem>
                        <ls:LSListBox ItemsSource="{Binding Features.Boosts}" Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                            <ls:LSListBox.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Template="{StaticResource CharacterSheetFeature}" ToolTip="{StaticResource ManagedTooltip}"
                                                    ToolTipService.Placement="Left">
                                            <TextBlock Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource MediumFontSize}" TextWrapping="Wrap" >
                                                <b:Interaction.Behaviors>
                                                    <ls:CtxTransStringRunGeneratorBehavior Source="{Binding NameCTS}" ParamRunStyle="{StaticResource TooltipUnitParamRun}"/>
                                                </b:Interaction.Behaviors>
                                            </TextBlock>
                                    </ContentControl>
                                </DataTemplate>
                            </ls:LSListBox.ItemTemplate>
                        </ls:LSListBox>
                        <ls:LSListBoxItem.Style>
                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Features.Boosts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ls:LSListBoxItem.Style>
                    </ls:LSListBoxItem>

                    <ls:LSListBoxItem>
                        <ls:LSListBox ItemsSource="{Binding Features.Abilities}" Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                            <ls:LSListBox.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Template="{StaticResource CharacterSheetFeature}" ToolTip="{StaticResource ManagedTooltip}">
                                        <Control Template="{StaticResource AbilityText}"/>
                                    </ContentControl>
                                </DataTemplate>
                            </ls:LSListBox.ItemTemplate>
                        </ls:LSListBox>
                        <ls:LSListBoxItem.Style>
                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Features.Abilities.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ls:LSListBoxItem.Style>
                    </ls:LSListBoxItem>                  
                </ls:LSListBox>

                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="Frame" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_frame_listItem.png"/>
                        <Setter TargetName="Highlight" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_selector_listItem.png"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding IsToggled}" Value="false">
                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="Frame" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_frame_listItem.png"/>
                        <Setter TargetName="Highlight" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SheetGeneral_c/c_selector_listItem.png"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:LSListBoxItem}}, Path=IsSelected}" Value="True">
                        <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <Style x:Key="icon" TargetType="Image">
                <Setter Property="DockPanel.Dock" Value="Left"/>
                <Setter Property="Stretch" Value="None"/>
                <Setter Property="Margin" Value="24,0,0,0"/>
            </Style>
            <Style x:Key="leftText" TargetType="TextBlock">
                <Setter Property="DockPanel.Dock" Value="Left"/>
                <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                <Setter Property="Margin" Value="16,4,0,0"/>
            </Style>
            <Style x:Key="rightText" TargetType="TextBlock">
                <Setter Property="DockPanel.Dock" Value="Right"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                <Setter Property="Margin" Value="0,4,32,0"/>
            </Style>

            <Style x:Key="ElementDock" TargetType="DockPanel">
                <Setter Property="Margin" Value="16,0,36,0"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <DataTemplate x:Key="ObjectSizeTemplate">
                <DockPanel Style="{StaticResource ElementDock}">
                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/ico_size.png" Style="{StaticResource icon}"/>
                    <TextBlock Text="{Binding Source='hfc7ce51bga5d6g4711g8e19g3fcebf236de0', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"/>
                    <TextBlock x:Name="ObjSize" Text="" Style="{StaticResource rightText}"/>
                </DockPanel>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Tiny">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='hd9415e41gcd92g47ddga4c2gfb4b3bbba45b', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Small">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='hef9e942bg4375g4accg8ca3g5a2fb95f0a02', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Medium">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='h597ef1deg4b4fg4387gbf1bg1b2314ab82e9', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Large">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='h58df9296gf2bag43abgbc12g19d478eb78d2', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Huge">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='hbba27962g6901g4564g977fgebccac49d12a', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ObjectSize}" Value="Gargantuan">
                        <Setter TargetName="ObjSize" Property="Text" Value="{Binding Source='he5d3cb78ge031g4233g9dfag5273c98c96b6', Converter={StaticResource TranslatedStringConverter}}"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

        </ResourceDictionary>
    </ls:UIWidget.Resources>

    <b:Interaction.Behaviors>
        <noesis:CollectionFilterBehavior x:Name="BoostSpellBehavior" ItemsSource="{Binding CurrentPlayer.UIData.ExamineItemData.Boosts}" Predicate="{Binding CurrentPlayer.UIData.BoostSpellPredicate}"/>
        <noesis:CollectionFilterBehavior x:Name="BoostNonSpellBehavior" ItemsSource="{Binding CurrentPlayer.UIData.ExamineItemData.Boosts}" Predicate="{Binding CurrentPlayer.UIData.BoostNonSpellPredicate}"/>
    </b:Interaction.Behaviors>

    <Grid x:Name="bgFade" Background="{StaticResource LS_PopUpBackgroundColor}"  ls:TooltipExtender.Owner="{Binding CurrentPlayer.UIData.ExamineTarget}">

        <Grid.Resources>
            <ControlTemplate x:Key="ObjectConditions" TargetType="ls:LSListBoxItem">
                <StackPanel x:Name="ConditionsPanel" HorizontalAlignment="Center">
                    <TextBlock Margin="0,0,0,10" Text="{Binding Source='h3baf1fe2g7d16g4d77gbc35gc17a90fb27d6', Converter={StaticResource TranslatedStringConverter}}" 
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <ls:LSListBox Margin="0,0,0,10" ItemsSource="{Binding StatusEffects}" ItemTemplate="{StaticResource ConditionBarDataTemplate}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  BorderBrush="Transparent" Style="{StaticResource VerticalControllerExamineListBoxStyle}"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding StatusEffects.Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed" TargetName="ConditionsPanel"/>
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="CharacterAbilities" TargetType="ls:LSListBoxItem">
                <ls:LSListBox x:Name="content" HorizontalAlignment="Center" Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                    <ls:LSListBoxItem HorizontalAlignment="Center">
                        <TextBlock Margin="0,0,0,10" Text="{Binding Source='hd3f00e0ag520fg4d0cgbba3g5eeeeec98d91', Converter={StaticResource TranslatedStringConverter}}" 
                                   Style="{StaticResource SectionHeaderStyle}"/>
                    </ls:LSListBoxItem>

                    <ls:LSListBoxItem>
                        <ls:LSListBox ItemsSource="{Binding Stats.Abilities}" ItemTemplate="{StaticResource StatBarDataTemplate}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                        </ls:LSListBox>
                    </ls:LSListBoxItem>
                        
                    <ls:LSListBoxItem>
                        <ls:LSListBox Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                            <ls:LSListBoxItem Content="{Binding Stats.ProficiencyBonus}" ContentTemplate="{StaticResource BonusBarDataTemplate}" Margin="0,30,0,0"/>
                            <ls:LSListBoxItem Content="{Binding Stats.Initiative}" ContentTemplate="{StaticResource BonusBarDataTemplate}"/>
                        </ls:LSListBox>
                    </ls:LSListBoxItem>                    
                </ls:LSListBox>
                <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding Stats.Abilities.Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed" TargetName="content"/>
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="CharacterPassives" TargetType="ls:LSListBoxItem">
                <StackPanel x:Name="PassivesPanel" HorizontalAlignment="Center">
                    <TextBlock Margin="0,0,0,10" Text="{Binding Source='h74d1322ag4c4dg42eag9272g066b84d0d374',Converter={StaticResource TranslatedStringConverter}}" 
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <ls:LSListBox Margin="0,0,0,10" ItemsSource="{Binding Stats.Passives}" ItemTemplate="{StaticResource PassiveBarDataTemplate}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  Background="Transparent" Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                        <ls:LSListBox.ItemContainerStyle>
                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ls:LSListBox.ItemContainerStyle>
                    </ls:LSListBox>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding Stats.Passives.Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed" TargetName="PassivesPanel"/>
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="SectionPanel">
                <Grid HorizontalAlignment="Center">
                    <DockPanel>
                        <Image DockPanel.Dock="Top" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/frame_listItemParagraph_top.png" Stretch="None"/>
                        <Image DockPanel.Dock="Bottom" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/frame_listItemParagraph_bottom.png" Stretch="None"/>
                        <Grid>
                            <Grid.Background>
                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/frame_listItemParagraph_middle.png" TileMode="Tile"/>
                            </Grid.Background>
                        </Grid>
                    </DockPanel>
                    <ContentPresenter/>
                </Grid>
            </ControlTemplate>

            <ControlTemplate x:Key="ApprovalRatingTemplate" TargetType="ls:LSListBoxItem">
                <StackPanel>
                    <TextBlock Text="{Binding Source='hab8d8423g3797g4f2ega601g18f13af5add6',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SectionHeaderStyle}"/>
                    <ls:LSListBox x:Name="RatingsList" ItemsSource="{Binding ApprovalRatings}" ItemTemplate="{StaticResource ApprovalDataTemplate}"
                                  Style="{StaticResource VerticalControllerExamineListBoxStyle}"/>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ApprovalRatings.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>
            </ControlTemplate>

            <DataTemplate x:Key="PropertyListTemplate">
                <ContentControl Template="{StaticResource CharacterSheetDecorativeBoxFrame}" Width="800">
                    <StackPanel Orientation="Horizontal" Visibility="{Binding TypeId, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter='EmptyString'}">
                        <Image x:Name="PropertyIcon" HorizontalAlignment="Center" Stretch="None" Style="{StaticResource SectionImageStyle}" Margin="8,0,8,0" Width="64" Height="64"/>

                        <TextBlock Style="{StaticResource PropertyKeyStyle}" />
                        <TextBlock Style="{StaticResource PropertySeparatorStyle}"/>
                        <TextBlock Style="{StaticResource PropertyValueStyle}"/>
                    </StackPanel>
                </ContentControl>
            </DataTemplate>

            <DataTemplate x:Key="ExamineSectionTemplate">
                <StackPanel Background="Transparent">
                    <TextBlock Text="{Binding Header}" Style="{StaticResource SectionHeaderStyle}"/>
                    <ls:LSListBox ItemsSource="{Binding Details}" Style="{StaticResource VerticalControllerExamineListBoxStyle}">                        
                        <ls:LSListBox.ItemContainerStyle>
                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                <Setter Property="Focusable" Value="True"/>
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <ContentControl Template="{StaticResource CharacterSheetDecorativeBoxFrame}" Width="800">
                                                <DockPanel>
                                                    <Grid DockPanel.Dock="Left" Width="64" Height="64" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,0,8,0">
                                                        <Image Width="40" Height="40" Style="{StaticResource SectionImageStyle}"/>
                                                        <Rectangle Fill="{Binding Brush}" Width="48" Height="48"/>
                                                    </Grid>

                                                    <TextBlock Width="624" Style="{StaticResource TooltipSectionTextStyle}"> 
                                                    <b:Interaction.Behaviors>
                                                        <ls:CtxTransStringRunGeneratorBehavior LocaSource="{Binding Description}" ParamRunStyle="{StaticResource TooltipUnitParamRun}" />
                                                    </b:Interaction.Behaviors>
                                                    </TextBlock>
                                                </DockPanel>
                                            </ContentControl>                                            
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ls:LSListBox.ItemContainerStyle>
                    </ls:LSListBox>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Details.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>
            </DataTemplate>

        </Grid.Resources>
        <Grid x:Name="Panel" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0" 
              DataContext="{Binding CurrentPlayer.UIData.ExamineTarget}" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Grid.RenderTransform>
            
            <Border Width="2576" Height="1618" Background="Black" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="72,182,0,0">
                <ls:LSPaperdoll x:Name="ExaminePaperdoll" HorizontalAlignment="Left" EntityRef="{Binding EntityHandle}"  RenderScale="{Binding DataContext.Data.RenderScale, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Width="1800" Height="1618" UseCombatPose="True"/>
            </Border>
            <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Examine/inspect_bg.png" Stretch="None" IsHitTestVisible="False"/>
            <ls:LSButton Style="{DynamicResource CloseButton}" SoundID="UI_Shared_Cancel" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,8,0" BoundEvent="ToggleInGameMenu">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Click" >
                        <b:ControlStoryboardAction Storyboard="{StaticResource ClosePanelAnim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ls:LSButton>
            <ContentControl VerticalAlignment="Top" Focusable="False">
                <ContentControl.Template>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Top">
                            <ContentPresenter x:Name="portrait" ContentTemplate="{StaticResource CharacterPortraitTemplate}" VerticalAlignment="Top" HorizontalAlignment="Center" Content="{Binding}" Margin="0,46,0,0"/>

                            <Grid x:Name="icon" Visibility="Collapsed" Margin="0,94,0,0">
                                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Examine/item_image_bg.png" Stretch="None"/>
                                <Grid Background="{Binding Icon}" Width="100" Height="100"/>
                                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Examine/item_image_frame.png" Stretch="None"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Type}" Value="Item">
                                <Setter TargetName="portrait" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ContentControl.Template>
            </ContentControl>

            <ScrollViewer Template="{DynamicResource ScrollViewerTemplate}" Background="Transparent" VerticalScrollBarVisibility="Visible" Height="1608" HorizontalAlignment="Right" VerticalAlignment="Top"  Margin="0,186,38,0">
                <ScrollViewer.Resources>
                    <GridLength x:Key="Top">80</GridLength>
                    <GridLength x:Key="Bottom">80</GridLength>
                </ScrollViewer.Resources>

                <ls:LSListBox x:Name="RootList" Width="800" Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="LocalFocusChanged">
                            <b:InvokeCommandAction Command="{Binding DataContext.ShowTooltipOnUIElement, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding Path=LocalFocus, ElementName=RootList}"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <ls:LSListBoxItem HorizontalAlignment="Center">
                        <ls:LSListBox Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                            <ls:LSListBoxItem HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource TitleFontSize}" 
                               Width="650" TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,0" IsHitTestVisible="False"/>
                            </ls:LSListBoxItem>
                        </ls:LSListBox>
                    </ls:LSListBoxItem>

                    <ls:LSListBoxItem>
                        <ContentControl>
                            <ContentControl.Style>

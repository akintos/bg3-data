                                                                                </StackPanel>
                                                                            </ContentControl>
                                                                        </Grid>
                                                                        <DataTemplate.Triggers>
                                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:LSListBoxItem}}, Path=IsSelected}" Value="True">
                                                                                <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </DataTemplate.Triggers>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ls:LSListBox>
                                                        </StackPanel>
                                                        <ls:LSListBoxItem.Style>
                                                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ItemsSource.Count, ElementName=SpellBoosts}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ls:LSListBoxItem.Style>
                                                    </ls:LSListBoxItem>

                                                    <!--Conditions-->
                                                    <ls:LSListBoxItem Template="{StaticResource ObjectConditions}" Margin="0,10,0,0" HorizontalAlignment="Center">
                                                        <ls:LSListBoxItem.Style>
                                                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StatusEffects.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ls:LSListBoxItem.Style>
                                                    </ls:LSListBoxItem>



                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                        <TextBlock Text="{Binding Source='hc787ab0dg9a15g40b7g9102g2d40a2e98626', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"

                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}" ToolTipService.Placement="Left">
                                                                <ls:LSListBoxItem.ToolTip>
                                                                    <ls:LSTooltip Content="{Binding Source='hebda3a55g1c81g415cg8bb0g36fa526e5c1b', Converter={StaticResource TranslatedStringConverter}}"
                                                                                  ContentTemplate="{DynamicResource DescriptionTooltipContent}"/>
                                                                </ls:LSListBoxItem.ToolTip>
                                                                <ContentPresenter ContentTemplate="{StaticResource ObjectSizeTemplate}" Content="{Binding .}">
                                                                </ContentPresenter>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}"  DataContext="{Binding Stats.Weight}" ToolTip="{StaticResource ManagedTooltip}">
                                                                <DockPanel>
                                                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/ico_weightWhite.png" Style="{StaticResource icon}"/>
                                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource leftText}"/>
                                                                    <TextBlock Text="{Binding Value, Converter={StaticResource UnitConverter}, ConverterParameter='Weight Short N2'}" Style="{StaticResource rightText}"/>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}"  Visibility="{Binding Inventory, Converter={StaticResource NullToCollapsedConverter}}">
                                                                <ls:LSListBoxItem.ToolTip>
                                                                    <ls:LSTooltip Content="{Binding Source='he3984e57gf0b5g4a00g8feagb1cf74d23e64', Converter={StaticResource TranslatedStringConverter}}"
                                                                                  ContentTemplate="{DynamicResource DescriptionTooltipContent}"/>
                                                                </ls:LSListBoxItem.ToolTip>
                                                                <DockPanel>
                                                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/ico_weightWhite.png" Style="{StaticResource icon}"/>
                                                                    <TextBlock Text="{Binding Source='hfca30e45gdea2g40f4g9824gaa41fb2c88ef', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"/>
                                                                    <TextBlock Text="{Binding DataContext.CurrentPlayer.UIData.ExamineItemData.Weight,RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource UnitConverter}, ConverterParameter='Weight Short N2'}" Style="{StaticResource rightText}"/>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}"  Visibility="{Binding Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter={StaticResource IntCountOne}}">
                                                                <ls:LSListBoxItem.ToolTip>
                                                                    <ls:LSTooltip Content="{Binding Source='h016d1351g90ceg493agb176gb2cdffe2ca1e', Converter={StaticResource TranslatedStringConverter}}"
                                                                                  ContentTemplate="{DynamicResource DescriptionTooltipContent}"/>
                                                                </ls:LSListBoxItem.ToolTip>
                                                                <DockPanel>
                                                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/ico_weightWhite.png" Style="{StaticResource icon}"/>
                                                                    <TextBlock Text="{Binding Source='hd2f94edag012ag440fgbb17ge2b946378237', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"/>
                                                                    <TextBlock Text="{Binding DataContext.CurrentPlayer.UIData.ExamineItemData.Weight,RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource UnitConverter}, ConverterParameter='Weight Short N2'}" Style="{StaticResource rightText}"/>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}">
                                                                <ls:LSListBoxItem.ToolTip>
                                                                    <ls:LSTooltip Content="{Binding Source='h64136245g9affg405dg9c31g46f035545f3e', Converter={StaticResource TranslatedStringConverter}}"
                                                                                  ContentTemplate="{DynamicResource DescriptionTooltipContent}"/>
                                                                </ls:LSListBoxItem.ToolTip>
                                                                <DockPanel>
                                                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared/ico_coinWhite.png" Style="{StaticResource icon}"/>
                                                                    <TextBlock Text="{Binding Source='h90f733a7gb26eg450bg931fge0f7245cba18', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"/>
                                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                                        <TextBlock Text="{Binding Gold}" TextAlignment="Right" Foreground="{DynamicResource LS_PrimaryColor}" Margin="0,4,0,0"/>
                                                                        <Image Source="{StaticResource GoldIconImg}" Stretch="None" Margin="0,0,0,4"/>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}" 
                                                                              Visibility="{Binding Stats.Health.IsValid, Converter={StaticResource BoolToVisibleConverter}}">

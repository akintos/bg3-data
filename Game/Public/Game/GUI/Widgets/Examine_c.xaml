                                                                </ContentControl>
                                                                <ls:LSListBoxItem.ToolTip>
                                                                    <ls:LSTooltip Content="{Binding Source='hcd93833ag1000g48f9gb6f3g69b89475ee98', Converter={StaticResource TranslatedStringConverter}}"

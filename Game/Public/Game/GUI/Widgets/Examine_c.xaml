                                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource leftText}"/>
                                                                    <TextBlock Style="{StaticResource rightText}" HorizontalAlignment="Right">
                                                                        <Run Text="{Binding Value}"/><Run Text="{Binding Max, StringFormat='/{0}'}"/>
                                                                    </TextBlock>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>
                                                        </ls:LSListBox>
                                                    </ls:LSListBoxItem>

                                                    <ls:LSListBoxItem DataContext="{Binding DataContext.CurrentPlayer.UIData.ExamineItemData, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                                                                      Template="{StaticResource SectionPanel}" Margin="0,0,35,0" Focusable="False">
                                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Description}" Width="700" TextWrapping="Wrap" Margin="0,40,0,40" />
                                                        <ls:LSListBoxItem.Style>
                                                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Description}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ls:LSListBoxItem.Style>
                                                    </ls:LSListBoxItem>

                                                    <ls:LSListBoxItem x:Name="PropertySections" 
                                                                      DataContext="{Binding DataContext.CurrentPlayer.UIData.ExamineItemData, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 

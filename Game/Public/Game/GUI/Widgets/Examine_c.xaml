                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ls:LSListBoxItem.Style>
                                                            </ls:LSListBoxItem>

                                                            <ls:LSListBoxItem Template="{StaticResource sheetElementHolder}" Visibility="{Binding Stats.Range.IsValid,Converter={StaticResource BoolToVisibleConverter}}"

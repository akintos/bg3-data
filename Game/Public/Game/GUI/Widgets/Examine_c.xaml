                                                                    <TextBlock Text="{Binding Source='h489da407g8c63g442bgb59dg4f13763ceedd', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource leftText}"/>
                                                                </DockPanel>
                                                            </ls:LSListBoxItem>


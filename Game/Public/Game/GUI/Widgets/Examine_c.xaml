                                                                          Style="{StaticResource VerticalControllerExamineListBoxStyle}">
                                                                <ls:LSListBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <ContentControl x:Name="holder" Template="{StaticResource CharacterSheetDecorativeBoxFrame}" Width="800" ToolTipService.IsEnabled="{Binding CustomDataContext,Converter={StaticResource NullToBoolFalseConverter}}">
                                                                            <ContentControl.ToolTip>
                                                                                <ls:LSTooltip Content="{Binding DataContext.CustomDataContext, ElementName=holder}"/>
                                                                            </ContentControl.ToolTip>
                                                                            <DockPanel HorizontalAlignment="Center" MaxWidth="800" Margin="0, 10">
                                                                                <TextBlock ls:TextBlockFormatter.SourceText="{Binding Name}" FontSize="{StaticResource MediumFontSize}" TextWrapping="Wrap"
                                                                                    Foreground="{DynamicResource LS_PrimaryColor}" DockPanel.Dock="Left" />
                                                                                <TextBlock x:Name="value" Text="{Binding Value, StringFormat={}{0:+#;-#;''}}" FontSize="{StaticResource MediumFontSize}" TextWrapping="Wrap"
                                                                                    Foreground="{DynamicResource LS_PrimaryColor}" TextAlignment="Right" DockPanel.Dock="Right" />
                                                                            </DockPanel>
                                                                        </ContentControl>
                                                                        <DataTemplate.Triggers>
                                                                            <DataTrigger Binding="{Binding Value, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                                                <Setter TargetName="value" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding GUID}" Value="Movement">
                                                                                <Setter TargetName="value" Property="Text" Value="{Binding DValue,Converter={StaticResource UnitConverter}, ConverterParameter='Distance Short',StringFormat='+{0}'}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="Advantage">
                                                                                <Setter TargetName="holder" Property="ToolTipService.IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </DataTemplate.Triggers>
                                                                    </DataTemplate>
                                                                </ls:LSListBox.ItemTemplate>
                                                            </ls:LSListBox>
                                                        </StackPanel>
                                                        <ls:LSListBoxItem.Style>
                                                            <Style TargetType="ls:LSListBoxItem" BasedOn="{StaticResource {x:Type ls:LSListBoxItem}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ItemsSource.Count, ElementName=StatBoosts}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ls:LSListBoxItem.Style>
                                                    </ls:LSListBoxItem>


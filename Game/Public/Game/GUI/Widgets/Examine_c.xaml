                                                        <StackPanel Visibility="{Binding ItemsSource.Count, ElementName=StatBoosts, Converter={StaticResource CountToVisibilityConverter}}" Margin="-15, 0, 0, 0">
                                                            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{Binding Source='he6b402adgd1fag4d54gbef7gd18036efe898', Converter={StaticResource TranslatedStringConverter}}" Margin="0,12,0,0"/>

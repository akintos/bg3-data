                            </Storyboard>
                        </Grid.Resources>

                        <ls:LSButton x:Name="HoldReleaseConcentrationButton" EatInput="False" TapTime="200" Content="{Binding Source='h1018e7a5gdb9ag4b51g9898gc30c5b0ab518',Converter={StaticResource TranslatedStringConverter}, ConverterParameter='Loca'}" DataContext="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMarkWares'}">
                            <ls:LSButton.Style>
                                <Style TargetType="ls:LSButton" BasedOn="{StaticResource ControllerButtonWBG}">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.HotbarActive, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                                                <Condition Binding="{Binding DataContext.CurrentPlayer.SelectedCharacter.ConcentrationSpell, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource NullToBoolFalseConverter}}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <MultiDataTrigger.Setters>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger.Setters>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ls:LSButton.Style>

                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSButtonPressed">
                                    <b:ControlStoryboardAction Storyboard="{StaticResource HoldReleaseConcentrationAnim}"/>
                                </b:EventTrigger>
                                <b:EventTrigger EventName="LSButtonReleased">
                                    <b:ControlStoryboardAction Storyboard="{StaticResource HoldReleaseConcentrationAnim}" ControlStoryboardOption="Stop"/>
                                </b:EventTrigger>
                                <b:StoryboardCompletedTrigger Storyboard="{StaticResource HoldReleaseConcentrationAnim}">
                                    <b:InvokeCommandAction Command="{Binding DataContext.ReleaseConcentrationCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding DataContext.CurrentPlayer.SelectedCharacter, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                    <b:ControlStoryboardAction Storyboard="{StaticResource HoldReleaseConcentrationAnim}" ControlStoryboardOption="Stop"/>
                                </b:StoryboardCompletedTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>

                        <ls:LSPie x:Name="HoldReleaseConcentrationPie" Value="0" SweepDirection="Clockwise" HorizontalAlignment="Right" Margin="0,0,10,0"
                              Visibility="{Binding ElementName=HoldReleaseConcentrationButton, Path=IsPressed, Converter={StaticResource BoolToVisibleConverter}}">
                            <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Shared_c/c_tabSelector.png" Width="100" Height="100"/>
                        </ls:LSPie>
                    </Grid>
                </StackPanel>

                <!-- Toggle Bottom bar button-->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" x:Name="BottomBarButton" Margin="0,0,0,-20">
                    <TextBlock Text="{Binding Source='h73880dc7ga260g4f04gab87ga0afe4b0794e',Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_InputTypeColor}" 
                           noesis:Text.Stroke="Black" noesis:Text.StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <ls:LSButton x:Name="ShowBottomBar" TapTime="300" 
                             Command="{Binding DataContext.ToggleControllerHotBar, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                             CommandParameter="{Binding ., ElementName=slotList}"
                             Style="{StaticResource ControllerButtonWBG}" EatInput="False"  
                             IsEnabled="{Binding DataContext.AssigningSlot, Converter={StaticResource InvertBoolConverter}, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                             DataContext="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleSpells'}" 
                             Content="{Binding Source='h6de3e261g3497g4035ga02bg80321b5102e8',Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}"/>
                </StackPanel>

                <!-- FTB Mode Button Hint -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" x:Name="FTBButton">
                    <StackPanel.Resources>
                        <Style x:Key="OverriddenStyle" TargetType="ls:LSButton" BasedOn="{StaticResource ControllerButtonWBG}">
                            <Setter Property="Margin" Value="0,0,0,-18"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="{Binding Source='h73880dc7ga260g4f04gab87ga0afe4b0794e',Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_InputTypeColor}" 
                               noesis:Text.Stroke="Black" noesis:Text.StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ls:LSButton Command="{Binding DataContext.ToggleTurnBasedMode, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Style="{StaticResource ControllerButtonWBG}"
                                 DataContext="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleManualTurnBasedMode'}" 
                                 Content="{Binding Source='ha5a5fa29g006cg46d8g8091g2e3b0ac01018',Converter={StaticResource TranslatedStringConverter}}" 
                                 IsEnabled="{Binding DataContext.AssigningSlot, Converter={StaticResource InvertBoolConverter}, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                 Foreground="{StaticResource LS_PrimaryColor}" HorizontalAlignment="Right"/>
                </StackPanel>
            </StackPanel>

            <ls:LSInputBinding Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="PanelSelect" BoundEvent="PanelSelect"/>
            <ls:LSInputBinding Command="{Binding DataContext.UseSlotCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" BoundEvent="UIAccept" IsEnabled="{Binding InputEnabled}" TriggerOnRelease="True">
                <ls:LSInputBinding.CommandParameter>
                    <MultiBinding  Converter="{StaticResource PassThroughConverter}">
                        <Binding ElementName="slotList" Mode="OneWay" Path="LocalFocus"/>
                        <Binding Source="Top"/>
                        <Binding Path="DataContext.UseFlyOutSlotCommand" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                    </MultiBinding>
                </ls:LSInputBinding.CommandParameter>
            </ls:LSInputBinding>
            <!-- Pressing the cancel button with the hotbar active would deactivate the hotbar -->
            <ls:LSInputBinding Command="{Binding DataContext.ToggleControllerHotBar, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" IsEnabled="{Binding DataContext.InputEnabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" BoundEvent="UICancel" SoundID=""/>
        </Grid>

        <!-- Slot assigning pop-up-->
        <Control x:Name="SlotAssignHolder" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Control.Style>
                <Style TargetType="Control">
                    <Setter Property="Template" Value="{x:Null}"/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AssigningSlot}" Value="True">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Grid x:Name="SlotAssignTemplate" >
                                            <Grid x:Name="bgFade" Background="{DynamicResource LS_PopUpBackgroundColor}"/>

                                            <ContentControl Template="{StaticResource BaseTooltipTemplate}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid Height="800" MaxHeight="800">
                                                    <ls:LSListBox x:Name="AssignList" Background="Black" KeyboardNavigation.DirectionalNavigation="Cycle" ActionNextEvent="UIDown" ActionPrevEvent="UIUp" SelectedIndex="0"
                                                                  LocalFocusSelector="{Binding ElementName=SelectorAssign,Mode=OneWay}" Height="800" ItemTemplate="{StaticResource SpellGroupList}">
                                                        <ls:LSListBox.ToolTip>
                                                            <ls:LSTooltip x:Name="assignSlotTooltip" VerticalAlignment="Bottom" Margin="150,0,0,500" />
                                                        </ls:LSListBox.ToolTip>
                                                        <ls:LSListBox.Template>
                                                            <ControlTemplate TargetType="{x:Type ListBox}">
                                                                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible" Padding="0,0,-20,0" Template="{StaticResource ScrollViewerTemplate}" >
                                                                    <ScrollViewer.Resources>
                                                                        <GridLength x:Key="Top">40</GridLength>
                                                                        <GridLength x:Key="Bottom">40</GridLength>
                                                                    </ScrollViewer.Resources>
                                                                    <ItemsPresenter/>
                                                                </ScrollViewer>
                                                            </ControlTemplate>
                                                        </ls:LSListBox.Template>

                                                        <ls:LSListBox.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <ls:LSVirtualizingStackPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ls:LSListBox.ItemsPanel>

                                                        <!-- Spells & actions list -->
                                                        <ls:LSListBoxItem HorizontalAlignment="Center">
                                                            <ls:LSListBox x:Name="SpellGroupList" ItemsSource="{Binding CurrentPlayer.SelectedCharacter.SpellsAndActions}" ActionNextEvent="UIDown" ActionPrevEvent="UIUp" ItemTemplate="{StaticResource SpellGroupList}" KeyboardNavigation.DirectionalNavigation="Continue" MaxWidth="860" Template="{DynamicResource ScrolllessListBox}">
                                                                <ls:LSListBox.ItemContainerStyle>
                                                                    <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                            </Trigger>
                                                                            <DataTrigger Binding="{Binding Actions.Count}" Value="0">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ls:LSListBox.ItemContainerStyle>
                                                            </ls:LSListBox>
                                                        </ls:LSListBoxItem>

                                                        <!-- Inventory list -->
                                                        <ls:LSListBoxItem HorizontalAlignment="Center" x:Name="InventoryListHolder">
                                                            <ls:LSListBox ItemsSource="{Binding CurrentPlayer.SelectedCharacterPartyInvView.InventoryViewSlots}" Style="{StaticResource InventoryGrid}" KeyboardNavigation.DirectionalNavigation="Continue" MaxWidth="860" Template="{DynamicResource ScrolllessListBox}">
                                                                <ls:LSListBox.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <ls:LSGrid ActionUpEvent="UIUp" ActionDownEvent="UIDown" ActionRightEvent="UIRight" ActionLeftEvent="UILeft" AutoIndex="True" ContainerData="{Binding }" Columns="5" CellWidth="120" CellHeight="120" DisableScrolling="True" EmptyCellTemplate="{DynamicResource EmptyCellTemplate}"/>
                                                                    </ItemsPanelTemplate>
                                                                </ls:LSListBox.ItemsPanel>
                                                            </ls:LSListBox>
                                                        </ls:LSListBoxItem>

                                                        <b:Interaction.Triggers>
                                                            <b:EventTrigger EventName="LocalFocusChanged">
                                                                <!-- Make sure the Content is set on the LSToolTip before ShowTooltipOnUIElement is called -->
                                                                <b:ChangePropertyAction TargetName="assignSlotTooltip" PropertyName="Content" Value="{Binding LocalFocus.DataContext, ElementName=AssignList}" />
                                                                <b:InvokeCommandAction IsEnabled="{Binding LocalFocus, ElementName=AssignList,Converter={StaticResource NullToBoolFalseConverter}}" Command="{Binding ShowTooltipOnUIElement}" CommandParameter="{Binding ., ElementName=AssignList}"/>
                                                                <b:InvokeCommandAction IsEnabled="{Binding LocalFocus, ElementName=AssignList,Converter={StaticResource NullToBoolTrueConverter}}" Command="{Binding ShowTooltipOnUIElement}" CommandParameter="{x:Null}"/>
                                                            </b:EventTrigger>
                                                        </b:Interaction.Triggers>
                                                    </ls:LSListBox>

                                                    <Control x:Name="SelectorAssign" IsHitTestVisible="False" VerticalAlignment="Top" HorizontalAlignment="Left" Template="{StaticResource SelectorTemplate}" Visibility="{Binding Visibility, ElementName=AssignList}"/>
                                                </Grid>
                                            </ContentControl>

                                            <StackPanel x:Name="BtnHintStackPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,500">
                                                <StackPanel.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform></ScaleTransform>
                                                    </TransformGroup>
                                                </StackPanel.RenderTransform>
                                                <!-- Assign Slot-->
                                                <ls:LSButton VerticalAlignment="Center" x:Name="AssignButton" Style="{StaticResource ControllerButtonWBG}"
                                                             DataContext = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}" 
                                                             Content="{Binding Source='h4bd4a624g0355g43a2g8edeg4572473b0827',Converter={StaticResource TranslatedStringConverter}}"
                                                             Command="{Binding DataContext.AssignSlotCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                                             CommandParameter="{Binding LocalFocus.DataContext, ElementName=AssignList}"/>

                                                <!-- Navigate button -->
                                                <ls:LSButton VerticalAlignment="Center" Style="{StaticResource ControllerButtonWBG}"
                                                             DataContext="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMove'}" 
                                                             Content="{Binding Source='h5c405124g4622g4197g9239gb635f371bf0e', Converter={StaticResource TranslatedStringConverter}}"/>

                                                <!-- Cancel button -->
                                                <ls:LSButton VerticalAlignment="Center" Style="{StaticResource ControllerButtonWBG}"
                                                             DataContext ="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                                             Content="{Binding Source='h43f0dd5cg543cg46f5gaa87g4f14f4803cd1',Converter={StaticResource TranslatedStringConverter}}"
                                                             Command="{Binding DataContext.AssignSlotCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                                             CommandParameter=""/>
                                            </StackPanel>

                                            <Grid.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard >
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="bgFade" >
                                                                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.50" Value="1">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                            </DoubleAnimationUsingKeyFrames>

                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)"  Storyboard.TargetName="BtnHintStackPanel">
                                                                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                            </DoubleAnimationUsingKeyFrames>

                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" Storyboard.TargetName="BtnHintStackPanel">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>

                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.38" Value="1">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                            </DoubleAnimationUsingKeyFrames>
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" Storyboard.TargetName="BtnHintStackPanel">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>

                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.38" Value="1">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                            </DoubleAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Grid.Triggers>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Control.Style>
        </Control>

        <b:Interaction.Triggers>
            <b:PropertyChangedTrigger Binding="{Binding Path=CurrentPlayer.SelectedCharacter}">
                <!-- Reset HotBar when SelectedCharacter is changed -->
                <b:InvokeCommandAction Command="{Binding ClearSingleHotbarCommand}"/>
            </b:PropertyChangedTrigger>

            <b:DataTrigger Comparison="Equal" Value="{StaticResource TrueValue}">
                <b:DataTrigger.Binding>
                    <MultiBinding Mode="OneWay" Converter="{StaticResource BoolAndConverter}">
                        <Binding Path="CurrentActiveSlot.IsActive" Converter="{StaticResource InvertBoolConverter}"/>
                        <Binding Path="CanHideActiveSlotFilter"/>
                    </MultiBinding>
                </b:DataTrigger.Binding>
                <b:InvokeCommandAction Command="{Binding ClearSingleHotbarCommand}"/>
            </b:DataTrigger>
        </b:Interaction.Triggers>
    </Grid>

</ls:UIWidget> 

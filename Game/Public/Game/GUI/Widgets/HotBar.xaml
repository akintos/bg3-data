                    <ls:LSButton Width="228" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,16,0,0" Command="{Binding StartLevelUp}" CommandParameter="{Binding CurrentPlayer.SelectedCharacter}" ls:TutorialProperties.TargetID="TUT_LevelUp" ls:TutorialProperties.ModalType="Bottom">

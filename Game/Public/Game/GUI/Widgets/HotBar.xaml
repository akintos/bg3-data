                                        <Setter Property="Text" Value="{Binding Source='ha726741fg9519g4141ga6cageee7348046d0', Converter={StaticResource TranslatedStringConverter}}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

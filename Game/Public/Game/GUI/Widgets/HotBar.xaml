                                        <Rectangle Fill="{Binding DataContext.CurrentActiveSlot.Spell.Icon, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Width="{StaticResource HotbarSlotIconSize}" Height="{StaticResource HotbarSlotIconSize}" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <ItemsPresenter VerticalAlignment="Center"/>

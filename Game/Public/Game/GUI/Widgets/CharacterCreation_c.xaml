                <ContentControl Template="{StaticResource CommonCharacterCreationPanel}">
                    <Control Template="{StaticResource AppearanceTemplate}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="Loaded">
                                <ls:SetMoveFocusAction TargetName="CharacterCreation_c"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </Control>
                </ContentControl>
            </ControlTemplate>


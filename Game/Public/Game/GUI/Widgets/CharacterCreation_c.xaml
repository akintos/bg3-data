                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="focusedBorder" Property="BorderBrush" Value="{DynamicResource LS_PrimaryColor}"/>
                                        <Setter TargetName="playVoice" Property="IsEnabled" Value="True"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>

                    </Control>

                    <!-- Face -->
                    <TextBlock Text="{Binding Source='h800369a8g9201g4e9dg88a0g37f311fbcd18', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource PanelHeaderText}"/>

                                                <TextBlock Text="{Binding Source='h3e86cbedg1814g4052gb29fg51ae4e1e9f05', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource MediumFontSize}" Margin="20,0,0,0"/>

                    <TextBlock x:Name="ItemAmount" Text="{Binding ItemViewAmount, Converter={StaticResource AbbreviateNumberConverter}}" IsHitTestVisible="False" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="{Binding ItemViewAmount, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=1}" Style="{StaticResource ItemAmountTextStyle}"/>

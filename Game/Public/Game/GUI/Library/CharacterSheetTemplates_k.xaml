                    <TextBlock Grid.Row="0" Text="{Binding Source='h98a4ccfbg20f4g4294g9bf7g624c95711539',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center"/>


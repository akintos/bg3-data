                    </ls:LSNineSliceImage>

                    <Control Template="{StaticResource CharacterSheetInfotipTemplate}" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,18,26,0" ToolTipService.Placement="Right" ToolTipService.HorizontalOffset="20">

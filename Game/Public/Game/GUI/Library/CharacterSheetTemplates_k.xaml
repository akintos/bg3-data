                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel" Value="{StaticResource SpellbookDefaultItemsPanelTemplate}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SpellSlotGridItemContainerStyle}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Path=(ls:TooltipExtender.Owner).SpellbookIsListView, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                <Setter Property="ItemsPanel" Value="{StaticResource SpellbookListItemsPanelTemplate}"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource SpellSlotListItemContainerStyle}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type ls:VMActionGroup}">
        <ItemsControl x:Name="ActionsControl" ItemsSource="{Binding Actions}" Template="{StaticResource SpellbookGroup}" AlternationCount="{Binding Actions.Count}" ItemsPanel="{StaticResource SpellbookDefaultItemsPanelTemplate}" ItemContainerStyle="{StaticResource SpellSlotGridItemContainerStyle}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ls:LSButton x:Name="Container" Command="{Binding DataContext.ToggleCharacterAction, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.Placement="Right" Template="{StaticResource SpellContentGridTemplate}">
                        <ls:LSButton.ToolTip>
                            <ls:LSTooltip Content="{TemplateBinding DataContext}" IsHitTestVisible="False"/>
                        </ls:LSButton.ToolTip>
                        <b:Interaction.Behaviors>
                            <ls:DragCharacterActionBehavior CharacterAction="{Binding}" />
                        </b:Interaction.Behaviors>
                    </ls:LSButton>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Path=(ls:TooltipExtender.Owner).SpellbookIsListView, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                            <Setter TargetName="Container" Property="Template" Value="{StaticResource SpellContentListTemplate}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=(ls:TooltipExtender.Owner).SpellbookIsListView, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                <Setter TargetName="ActionsControl" Property="ItemsPanel" Value="{StaticResource SpellbookListItemsPanelTemplate}"/>
                <Setter TargetName="ActionsControl" Property="ItemContainerStyle" Value="{StaticResource SpellSlotListItemContainerStyle}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="SpellGroupItemContainerStyle" TargetType="ContentPresenter">
        <Setter Property="Margin" Value="{StaticResource SpellGroupSpacing}"/>
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Actions.Count}" Value="0">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource Mode=Self}}" Value="0">
                <Setter Property="Margin" Value="0"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="PreparedSpellsSlotTemplate" >
        <Grid x:Name="Container" Background="Transparent" d:DataContext="{d:DesignInstance {x:Type ls:VMCharacterAction}, IsDesignTimeCreatable=True}">
            <Rectangle x:Name="Icon" Fill="{Binding Icon}" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Grid x:Name="hover" Visibility="Collapsed"  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Rectangle x:Name="hoverRect" Fill="#66FFFFFF" Width="80" Height="80"/>
                <Ellipse Fill="#66FFFFFF" Visibility="{Binding Visibility, ElementName=hoverRect, Converter={StaticResource InvertVisibilityConverter}}" Width="80" Height="80"/>
                <ContentPresenter/>
            </Grid>
            <Image x:Name="Border" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/frame_prepared.png" Stretch="None" VerticalAlignment="Bottom" Visibility="Hidden"/>
        </Grid>

        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding Datacontext, RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource NullToBoolTrueConverter}}" Value="True">
                <Setter Property="IsEnabled" Value="False"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=IsMouseOver, RelativeSource={RelativeSource Mode=Self}}" Value="True"/>
                    <Condition Binding="{Binding Datacontext, RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="hover" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="PreparedSpellsHeaderTemplate">
        <StackPanel>
            <StackPanel.Resources>
                <Style x:Name="TitleHeaderTextStyle" TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource LS_tint00}"/>
                    <Setter Property="FontSize" Value="{StaticResource SmallFontSize}"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="MaxWidth" Value="500"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </StackPanel.Resources>

            <!-- Always Prepared -->
            <StackPanel x:Name="AlwaysPreparedTitle" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding AlwaysPreparedActions.Count, Converter={StaticResource CountToVisibilityConverter}}" Margin="0,0,0,10">
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/decoration_header.png" Stretch="None" Margin="0,0,12,0"/>
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/ico_inherent_header.png" Stretch="None"/>
                <TextBlock Style="{DynamicResource TitleHeaderTextStyle}" ls:TextBlockFormatter.SourceText="{Binding Source='h93f90c60g2e40g436agb4e1g3deb70712d55', Converter={StaticResource TranslatedStringConverter}}"/>
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/decoration_header.png" Stretch="None" Margin="12,0,0,0"/>
            </StackPanel>
            <ItemsControl VerticalAlignment="Top" HorizontalAlignment="Center" ItemsSource="{Binding AlwaysPreparedActions}" Visibility="{Binding AlwaysPreparedActions.Count, Converter={StaticResource CountToVisibilityConverter}}" ItemContainerStyle="{StaticResource SpellSlotGridItemContainerStyle}" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel MaxWidth="{StaticResource SpellbookSpellListWidth}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="ls:VMCharacterAction">
                        <ContentControl ToolTipService.Placement="Right">
                            <ContentControl.ToolTip>
                                <ls:LSTooltip Content="{TemplateBinding DataContext}" IsHitTestVisible="False"/>
                            </ContentControl.ToolTip>
                            <b:Interaction.Behaviors>
                                <ls:DragCharacterActionBehavior CharacterAction="{Binding}" />
                            </b:Interaction.Behaviors>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="BackgroundTile" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/slots_preprepared.png" Stretch="None"/>
                                <ls:LSButton x:Name="SlotButton" Template="{StaticResource PreparedSpellsSlotTemplate}"/>
                                <TextBlock x:Name="SpellSlotLevel" Text="{Binding SpellSlotLevel, Converter={StaticResource DecimalToRomanConverter}}" Foreground="{StaticResource LS_tint100}" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsHitTestVisible="False" Margin="0,0,12,0" FontSize="{StaticResource MediumFontSize}" FontWeight="Bold" noesis:Text.Stroke="{StaticResource LS_tint00}" noesis:Text.StrokeThickness="5"/>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Prepared -->
            <StackPanel x:Name="PreparedTitle" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding ManuallyPreparedActions.Count, Converter={StaticResource CountToVisibilityConverter}}" Margin="0,0,0,10">
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/decoration_header.png" Stretch="None" Margin="0,0,12,0"/>
                <TextBlock Style="{DynamicResource TitleHeaderTextStyle}" ls:TextBlockFormatter.SourceText="{Binding Source='h93fa2099gfd9cg46a0g9af4gd64345e6db72', Converter={StaticResource TranslatedStringConverter}}"/>
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/decoration_header.png" Stretch="None" Margin="12,0,0,0"/>
            </StackPanel>
            <ItemsControl VerticalAlignment="Top" HorizontalAlignment="Center" ItemsSource="{Binding ManuallyPreparedActions}" Visibility="{Binding ManuallyPreparedActions.Count, Converter={StaticResource CountToVisibilityConverter}}" ItemContainerStyle="{StaticResource SpellSlotGridItemContainerStyle}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel MaxWidth="{StaticResource SpellbookSpellListWidth}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="ls:VMCharacterAction">
                        <ContentControl x:Name="Container" ToolTipService.Placement="Right" ls:DragAndDropProperties.DropTargetOwner="{Binding Path=(ls:TooltipExtender.Owner), RelativeSource={RelativeSource Mode=Self}}">
                            <ContentControl.ToolTip>
                                <ls:LSTooltip Content="{TemplateBinding DataContext}" IsHitTestVisible="False"/>
                            </ContentControl.ToolTip>
                            <b:Interaction.Behaviors>
                                <ls:DragCharacterActionBehavior CharacterAction="{Binding }"/>
                                <ls:DropOnGenericBehavior DropCommand="{Binding DataContext.DropPrepareCharacterAction, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                            </b:Interaction.Behaviors>
                            <Grid>
                                <Border x:Name="BackgroundTile" IsHitTestVisible="False" Background="{StaticResource SlotBackgroundSpells}"/>
                                <ls:LSButton x:Name="SlotButton" Command="{Binding DataContext.ToggleCharacterAction, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" Template="{StaticResource PreparedSpellsSlotTemplate}">
                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/remover_spellslot.png" Stretch="None"/>
                                </ls:LSButton>
                                <TextBlock x:Name="SpellSlotLevel" Text="{Binding SpellSlotLevel, Converter={StaticResource DecimalToRomanConverter}}" Foreground="{StaticResource LS_tint100}" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsHitTestVisible="False" Margin="0,0,12,0" FontSize="{StaticResource MediumFontSize}" FontWeight="Bold" noesis:Text.Stroke="{StaticResource LS_tint00}" noesis:Text.StrokeThickness="5"/>
                            </Grid>
                        </ContentControl>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext, RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource NullToBoolTrueConverter}}" Value="True">
                                <Setter TargetName="Container" Property="ToolTip" Value="{x:Null}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding AlwaysPreparedActions.Count}" Value="0">
                <Setter TargetName="PreparedTitle" Property="Margin" Value="0,0,0,10"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <DataTemplate x:Key="SpellbookInfotipTooltipTemplate">
        <StackPanel Orientation="Vertical" MaxWidth="{StaticResource MaxTooltipContentWidth}">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="FontSize" Value="{DynamicResource ScaledMediumFontSize}"/>
                    <Setter Property="Foreground" Value="{StaticResource LS_baseTxtColor}"/>
                </Style>
            </StackPanel.Resources>

            <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='h23ac2ed9g60c8g4d02gaedag5f37282cd1a5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TooltipTitleStyle}"/>

            <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='hb33632e8ge575g4a1agb22egae1cf2e98e2c',Converter={StaticResource TranslatedStringConverter}}"/>
        </StackPanel>
    </DataTemplate>

    <ControlTemplate x:Key="SpellContentTemplate">
        <Grid x:Name="templateRoot" Height="1400">
            <b:Interaction.Behaviors>
                <ls:CollectionFilterBehavior x:Name="PassivesFilter" ItemsSource="{Binding Stats.Passives}" Predicate="{Binding TogglablePassivePredicate}"/>
                <ls:CollectionFilterBehavior x:Name="MetaMagicFilter" ItemsSource="{Binding Stats.Passives}" Predicate="{Binding TogglableMetaMagicPassivePredicate}"/>
                <ls:CollectionFilterBehavior x:Name="CantripGroupFilter" ItemsSource="{Binding SpellsAndActions}" Predicate="{Binding CantripGroupPredicate}"/>
                <ls:CollectionFilterBehavior x:Name="SpellLevelsGroupFilter" ItemsSource="{Binding SpellsAndActions}" Predicate="{Binding SpellLevelsGroupPredicate}" SortDirection="Ascending"/>
                <ls:CollectionFilterBehavior x:Name="ActionGroupFilter" ItemsSource="{Binding SpellsAndActions}" Predicate="{Binding ActionsGroupPredicate}"/>
            </b:Interaction.Behaviors>
            <Grid.RowDefinitions>
                <!-- Spells preparation header (can be collapsed) -->
                <RowDefinition Height="Auto"/>
                <!-- Spells preparation list or character actions -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Prepared and always prepared spells container (if character can prepare, it will be always visible and at the top) -->
            <Grid Grid.Row="0" x:Name="PrepareSpellsContainer" ZIndex="1" Margin="-8,0,0,0" Visibility="{Binding Stats.MustPrepareSpells, Converter={StaticResource BoolToVisibleConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Background part -->
                <Image Grid.Row="2" Visibility="{Binding IsChecked, ElementName=PrepareSpellToggle, Converter={StaticResource BoolToCollapsedConverter}}" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookScaler_bottom_extraCollapsed.png" Stretch="None" VerticalAlignment="Bottom" Margin="0,-12,0,0"/>

                <Image Grid.Row="0" Grid.RowSpan="2" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookScaler_bottom.png" Stretch="None" VerticalAlignment="Bottom" Margin="0,40,0,0"/>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="1" Margin="0,-120,0,0">
                        <Border.Background>
                            <ImageBrush TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,808,912" AlignmentX="Left" AlignmentY="Top" Stretch="None" ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookScaler_middle.png"/>
                        </Border.Background>
                    </Border>
                    <Image Grid.Row="0" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookScaler_top.png" Stretch="None" />
                </Grid>

                <!-- Content part -->
                <Control Grid.Row="0" Template="{StaticResource CharacterSheetInfotipTemplate}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,40,0" ToolTipService.Placement="Right">
                    <Control.ToolTip>
                        <ls:LSTooltip ContentTemplate="{StaticResource SpellbookInfotipTooltipTemplate}"/>
                    </Control.ToolTip>
                </Control>

                <!-- Control with always and manually prepared spells-->
                <Control Grid.Row="0" Template="{StaticResource PreparedSpellsHeaderTemplate}" Margin="0,60,0,0"/>

                <!-- Prepare & learn spells buttons -->
                <Grid Grid.Row="1" Margin="0,40">
                    <ls:LSToggleButton x:Name="PrepareSpellToggle" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="False">
                        <ls:LSToggleButton.Template>
                            <ControlTemplate TargetType="ls:LSToggleButton">
                                <Grid Background="Transparent">
                                    <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookBtn_bg.png" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                                    <Image x:Name="Bg" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_pill_d.png" Stretch="None" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ButtonText" Text="{Binding Source='h23ac2ed9g60c8g4d02gaedag5f37282cd1a5', Converter={StaticResource TranslatedStringConverter}}" FontSize="{StaticResource SmallFontSize}" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image x:Name="CollapseIcon" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Minimap/ico_plus_h.png" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,60,0"/>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Path=IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                        <Setter TargetName="CollapseIcon" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/Minimap/ico_minus_h.png"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_pill_h.png"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_pill_p.png"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bg" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_pill_disabled.png"/>
                                        <Setter TargetName="ButtonText" Property="Foreground" Value="{StaticResource LS_disabledTxtColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ls:LSToggleButton.Template>
                        <ls:LSToggleButton.ToolTip>
                            <ls:LSTooltip DataContext="{Binding Path=DataContext, RelativeSource={RelativeSource TemplatedParent}}">
                                <ls:LSTooltip.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" MaxWidth="{StaticResource MaxTooltipContentWidth}">
                                            <StackPanel.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                    <Setter Property="FontSize" Value="{DynamicResource ScaledMediumFontSize}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource LS_baseTxtColor}"/>
                                                </Style>
                                            </StackPanel.Resources>

                                            <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='h23ac2ed9g60c8g4d02gaedag5f37282cd1a5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TooltipTitleStyle}"/>

                                            <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='h1d8ce1dfg83e3g4930g87eag6caa149c8f57',Converter={StaticResource TranslatedStringConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ls:LSTooltip.ContentTemplate>
                            </ls:LSTooltip>
                        </ls:LSToggleButton.ToolTip>
                    </ls:LSToggleButton>

                    <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,28,0"  Visibility="{Binding Stats.CanLearnSpells, Converter={StaticResource BoolToVisibleConverter}}">
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/addBtn_bg.png" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        <ls:LSButton x:Name="LearnSpellsButton" Command="{Binding DataContext.OpenLearnSpellsCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Template="{StaticResource IconButtonTemplate}">
                            <ls:LSButton.Resources>
                                <ImageSource x:Key="IconNormal">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/ico_add_d.png</ImageSource>
                                <ImageSource x:Key="IconHighlight">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/ico_add_h.png</ImageSource>
                                <ImageSource x:Key="IconPressed">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/ico_add_h.png</ImageSource>
                                <ImageSource x:Key="IconDisabled">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/ico_add_d.png</ImageSource>
                                <ImageSource x:Key="ButtonNormal">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_small_pill_d.png</ImageSource>
                                <ImageSource x:Key="ButtonHighlight">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_small_pill_h.png</ImageSource>
                                <ImageSource x:Key="ButtonPressed">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_small_pill_p.png</ImageSource>
                                <ImageSource x:Key="ButtonDisabled">pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/btn_spellsbook_small_pill_disabled.png</ImageSource>
                                <System:Double x:Key="IconWidth">40</System:Double>
                                <System:Double x:Key="IconHeight">40</System:Double>
                            </ls:LSButton.Resources>
                            <ls:LSButton.IsEnabled>
                                <MultiBinding Converter="{StaticResource EqualConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}" Path="DataContext.CurrentPlayer.UserId"/>
                                    <Binding Path="OwnerUserID"/>
                                </MultiBinding>
                            </ls:LSButton.IsEnabled>
                            <ls:LSButton.CommandParameter>
                                <MultiBinding Converter="{StaticResource PassThroughConverter}">
                                    <Binding Path="DataContext" ElementName="templateRoot"/>
                                    <Binding ElementName="templateRoot"/>
                                    <Binding Source="800"/>
                                </MultiBinding>
                            </ls:LSButton.CommandParameter>
                            <ls:LSButton.ToolTip>
                                <ls:LSTooltip DataContext="{Binding Path=DataContext, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ls:LSTooltip.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical" MaxWidth="{StaticResource MaxTooltipContentWidth}">
                                                <StackPanel.Resources>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="FontSize" Value="{DynamicResource ScaledMediumFontSize}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource LS_baseTxtColor}"/>
                                                    </Style>
                                                </StackPanel.Resources>

                                                <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='h9784a948g9d80g41d8gbb18ga9c838b90edd',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TooltipTitleStyle}"/>

                                                <TextBlock ls:TextBlockFormatter.SourceText="{Binding Source='h1be7e965gcf8dg4a81gb85dga1fbc01a9f08',Converter={StaticResource TranslatedStringConverter}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ls:LSTooltip.ContentTemplate>
                                </ls:LSTooltip>
                            </ls:LSButton.ToolTip>
                        </ls:LSButton>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Spells (if doesn't require preparing spells), cantrips and character/class actions -->
            <ls:LSScrollViewer Grid.Row="1" Style="{DynamicResource OverlappingScrollViewer}" VerticalScrollBarVisibility="Auto" BookmarkSource="{Binding ElementName=SpellGroupList}" Padding="{TemplateBinding Padding}">
                <ls:LSScrollViewer.Resources>
                    <GridLength x:Key="Top">20</GridLength>
                    <GridLength x:Key="Bottom">20</GridLength>
                </ls:LSScrollViewer.Resources>

                <StackPanel x:Name="SpellbookOverview" Orientation="Vertical" Visibility="{Binding IsChecked, ElementName=PrepareSpellToggle, Converter={StaticResource BoolToHiddenConverter}}">
                    <!-- Spell Levels -->
                    <ItemsControl x:Name="SpellsCategories" VerticalAlignment="Top" HorizontalAlignment="Center" ItemsSource="{Binding Path=(b:Interaction.Behaviors)[3].FilteredItems, ElementName=templateRoot}" Visibility="{Binding Stats.MustPrepareSpells, Converter={StaticResource BoolToCollapsedConverter}}" AlternationCount="{Binding ItemsSource.Count,RelativeSource={RelativeSource Mode=Self}}" ItemContainerStyle="{StaticResource SpellGroupItemContainerStyle}"/>

                    <!-- Cantrips -->
                    <ItemsControl x:Name="CantripList" VerticalAlignment="Top" HorizontalAlignment="Center" ItemsSource="{Binding Path=(b:Interaction.Behaviors)[2].FilteredItems, ElementName=templateRoot}" Visibility="{Binding Path=(b:Interaction.Behaviors)[2].FilteredItems.Count, ElementName=templateRoot, Converter={StaticResource CountToVisibilityConverter}}"  Margin="{StaticResource SpellGroupSpacing}"/>

                    <!-- Metamagic -->
                    <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding Path=(b:Interaction.Behaviors)[1].FilteredItems, ElementName=templateRoot}" Template="{StaticResource SpellbookGroup}" ls:AttachedProperties.InheritedTag="MetaMagic" Visibility="{Binding Path=(b:Interaction.Behaviors)[1].FilteredItems.Count, ElementName=templateRoot, Converter={StaticResource CountToVisibilityConverter}}" Margin="{StaticResource SpellGroupSpacing}" Style="{StaticResource PassiveSlotLayoutSwapStyle}"/>

                    <!-- Actions -->
                    <ItemsControl x:Name="ActionsList" HorizontalAlignment="Center" ItemsSource="{Binding Path=(b:Interaction.Behaviors)[4].FilteredItems, ElementName=templateRoot}" AlternationCount="{Binding ItemsSource.Count,RelativeSource={RelativeSource Mode=Self}}" ItemContainerStyle="{StaticResource SpellGroupItemContainerStyle}" Margin="{StaticResource SpellGroupSpacing}" Visibility="{Binding Path=(b:Interaction.Behaviors)[4].FilteredItems.Count, ElementName=templateRoot, Converter={StaticResource CountToVisibilityConverter}}"/>

                    <!-- Passives -->
                    <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding Path=(b:Interaction.Behaviors)[0].FilteredItems, ElementName=templateRoot}" Template="{StaticResource SpellbookGroup}" ls:AttachedProperties.InheritedTag="Passives" Visibility="{Binding Path=(b:Interaction.Behaviors)[0].FilteredItems.Count, ElementName=templateRoot, Converter={StaticResource CountToVisibilityConverter}}" Margin="{StaticResource SpellGroupSpacing}" Style="{StaticResource PassiveSlotLayoutSwapStyle}"/>
                </StackPanel>
            </ls:LSScrollViewer>

            <!-- Prepare spells section (for classes that requires preparing)-->
            <Grid Grid.Row="1" x:Name="SpellbookPrepareOverlay" Visibility="{Binding IsChecked, ElementName=PrepareSpellToggle, Converter={StaticResource BoolToVisibleConverter}}" Margin="-8,-20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/SpellBook/spellbookScaler_expanded_top.png" Stretch="None" />
                <Border Grid.Row="1">
                    <Border.Background>

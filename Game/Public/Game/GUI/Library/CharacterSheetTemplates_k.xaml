                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Source='h529efdfdgda98g4ed3g8d1eg46cbf1d0a5e3', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SectionTitleTextStyle}"/>
                            </Grid>

                <!--<Rectangle x:Name="InventoryHolder" Height="468" Width="400" Fill="Pink"></Rectangle>-->
                <ListBox x:Name="InventoryHolder" Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="16,0,-16,0" ItemsSource="{Binding GeneratedItemsList, ElementName=FilteringContainerHolder}" ItemsPanel="{StaticResource InventoryGridTemplate}" Height="468">

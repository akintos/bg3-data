                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SimpleScrollBar}"/>
                                        <GridLength x:Key="Left">0</GridLength>
                                        <GridLength x:Key="Right">0</GridLength>
                                    </ScrollViewer.Resources>
                                    <b:Interaction.Behaviors>
                                        <ls:DragScrollingBehavior/>
                                    </b:Interaction.Behaviors>
                                    <ItemsPresenter Margin="0,0,0,10"/>
                                </ScrollViewer>
                                <Grid x:Name="DisabledDragOverlay" Visibility="Collapsed">
                                    <Rectangle Fill="{StaticResource LS_DisabledPanelColor}"/>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" ls:TextBlockFormatter.SourceText="{Binding Source='he59ced12g7c72g4310g9855g0aaae55efc38', Converter={StaticResource TranslatedStringConverter}}"/>
                                </Grid>
                                <Grid x:Name="NoItemsFoundOverlay" Visibility="Collapsed">
                                    <Rectangle Fill="{StaticResource LS_DisabledPanelColor}"/>
                                    <Control Template="{StaticResource NoResultsFoundTemplate}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0"/>
                                </Grid>

                            </Grid>
                            <ControlTemplate.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DataContext.CurrentPlayer.UIData.DragData.DraggingGameObjects.Count,Converter={StaticResource GreaterThanConverter}, ConverterParameter='0', RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                                        <Condition Binding="{Binding CurrentFilter, ElementName=FilteringContainerHolder, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="DisabledDragOverlay" Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DataContext.CurrentPlayer.UIData.DragData.DraggingGameObjects.Count,Converter={StaticResource GreaterThanConverter}, ConverterParameter='0', RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                                        <Condition Binding="{Binding IsChecked, ElementName=ChangePartyContextButton}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="DisabledDragOverlay" Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CurrentFilter, ElementName=FilteringContainerHolder, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                                        <Condition Binding="{Binding ItemsSource.Count, RelativeSource={RelativeSource Self}}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="NoItemsFoundOverlay" Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <!-- Hide the no items found overlay if we're attempting to drag-->
                                <DataTrigger Binding="{Binding Visibility, ElementName=DisabledDragOverlay}" Value="Visible">
                                    <Setter TargetName="NoItemsFoundOverlay" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ListBox.Template>
                </ListBox>

                <!-- Party image -->
                <Image Grid.Row="0" Grid.RowSpan="2" Source="{StaticResource PartyInvImg}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0" Width="750"
                       IsHitTestVisible="False" Panel.ZIndex="2" Visibility="{Binding IsChecked, ElementName=ChangePartyContextButton, Converter={StaticResource BoolToVisibleConverter}, ConverterParameter={StaticResource TrueValue}}"/>

                <!-- Weight bar -->
                <Control Template="{StaticResource WeightBarTemplate}" Margin="0,0,0,40" Grid.Row="2" HorizontalAlignment="Center"/>

                <!-- Filter -->
                <StackPanel x:Name="FiltersControl" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.RowSpan="3">
                    <ls:LSToggleButton x:Name="ExtendInventoryButton" Margin="0,4,0,0" SoundID="UI_HUD_InventoryResize" VerticalAlignment="Top" Template="{StaticResource ExtendInventoryButtonTemplate}" IsChecked="{Binding InventoryView.UseLargeView, Mode=TwoWay}"/>
                    <ls:LSToggleButton x:Name="SortToggleButton" Margin="16,4,0,0" Template="{StaticResource SortToggleButtonTemplate}" VerticalAlignment="Top"/>
                    <ls:LSToggleButton x:Name="ChangePartyContextButton" Margin="16,4,0,0" VerticalAlignment="Top" Template="{StaticResource ChangePartyContextToggleTemplate}"/>

                    <ls:FilteringContainer x:Name="FilteringContainerHolder" Margin="16,0,0,0" FilterPredicate="{Binding InventoryPredicate}" Template="{StaticResource FilterHolderTemplate}" CurrentFilter="{Binding DataContext.CurrentPlayer.UIData.GlobalSelectedFilter, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Mode=OneWay}" ItemsList="{Binding InventoryView.InventoryViewSlots}" MaxDisplayedFilters="7">
                        <ls:FilteringContainer.EnumFiltersList>
                            <ls:EnumFilterItem EnumId="gui::EPopularFilters" Label="h977af483ga6d9g4334g9ee0g3b85b94c67db" AlwaysVisible="True" />
                            <ls:EnumFilterItem EnumId="eoc::EProficiencyGroup" Label="ha4c5f0cfg93ebg47ecg8eecg6524ad70aee0" />
                        </ls:FilteringContainer.EnumFiltersList>

                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="FilterCleared">
                                <b:InvokeCommandAction Command="{Binding DataContext.ClearFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                <b:ChangePropertyAction TargetName="ChangePartyContextButton" PropertyName="IsChecked" Value="False"/>
                            </b:EventTrigger>

                            <b:PropertyChangedTrigger Binding="{Binding DataContext.CurrentPlayer.UIData.GlobalSelectedFilter, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}">
                                <b:ChangePropertyAction TargetName="FilteringContainerHolder" PropertyName="CurrentFilter" Value="{Binding DataContext.CurrentPlayer.UIData.GlobalSelectedFilter, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Mode=OneWay}"/>
                            </b:PropertyChangedTrigger>
                        </b:Interaction.Triggers>
                    </ls:FilteringContainer>
                </StackPanel>
            </Grid>
        </Grid>

        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding ElementName=AttackBonusBackground, Path=IsMouseOver}" Value="True">
                <Setter TargetName="AttackBonusHighlight" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ElementName=DamageBackground, Path=IsMouseOver}" Value="True">
                <Setter TargetName="AttackBonusHighlight" Property="Visibility" Value="Visible"/>
                <Setter TargetName="AttackBonusHighlight" Property="Margin" Value="0,0,0,-95"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, ElementName=ChangePartyContextButton}" Value="True">
                <Setter TargetName="FilteringContainerHolder" Property="ItemsList" Value="{Binding DataContext.CurrentPlayer.PartyInventoryView.InventoryViewSlots, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding InventoryView.UseLargeView}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InventoryHolder" Storyboard.TargetProperty="Height" >
                                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1300">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InventoryHolder" Storyboard.TargetProperty="Height" >
                                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="468">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

</ResourceDictionary>
                            </Ellipse>
                            <Image Source="{StaticResource BulletPointIconFilled}" Stretch="None" Width="48" Margin="8,0,8,0">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsToggled}" Value="True">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource LS_PrimaryColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <b:Interaction.Behaviors>
                        <ls:DragPassiveBehavior Passive="{Binding}" />
                    </b:Interaction.Behaviors>
                </ContentControl>
            </Grid>
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsToggled}" Value="True">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Expander x:Name="progressionExpander" Style="{StaticResource CharacterSheetExpanderStyle}" Margin="0,0,0,16">
                    <Expander.Header>
                        <ContentControl Template="{StaticResource CharacterSheetDecorativeBoxFrame}">
                            <StackPanel Orientation="Horizontal">
                                <Grid>
                                    <Rectangle Fill="{Binding Icon}" Width="40" Height="40" Margin="8,0,8,0">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToggled}" Value="False">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                    <Image Source="{StaticResource BulletPointIconFilled}" Stretch="None" Width="48" Margin="8,0,8,0">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToggled}" Value="True">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource LS_PrimaryColor}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <b:Interaction.Behaviors>
                                <ls:DragPassiveBehavior Passive="{Binding}" />
                            </b:Interaction.Behaviors>
                        </ContentControl>
                    </Expander.Header>
                    <ContentControl Template="{DynamicResource CharacterSheetProgressionFeatures}" />
                </Expander>
                <DockPanel x:Name="progressionNoExpander" Visibility="Collapsed" >
                    <Image Source="{StaticResource BulletPointIconFilled}" Stretch="None" Width="48" Margin="16,0,0,0"/>
                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource LS_PrimaryColor}" VerticalAlignment="Center"/>
                </DockPanel>
            </Grid>
        </Grid>
        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Features.Boosts.Count}" Value="0"/>
                    <Condition Binding="{Binding Features.Abilities.Count}" Value="0"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="progressionExpander" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="progressionNoExpander" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>


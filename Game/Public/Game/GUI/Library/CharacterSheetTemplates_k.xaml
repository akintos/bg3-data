            </DataTrigger>

            <DataTrigger Binding="{Binding Path=(b:Interaction.Behaviors)[0].FilteredItems.Count, ElementName=FilteringContainerHolder}" Value="0">
                <Setter TargetName="SpellResults" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Stats.MustPrepareSpells}" Value="True"/>
                    <Condition Binding="{Binding Path=(b:Interaction.Behaviors)[1].FilteredItems.Count, ElementName=FilteringContainerHolder}" Value="0"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="Results" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="SpellResults" Property="Margin" Value="0,20"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Stats.MustPrepareSpells}" Value="False"/>
                    <Condition Binding="{Binding GeneratedItemsList.Count, ElementName=FilteringContainerHolder}" Value="0"/>

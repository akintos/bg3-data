<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"

                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:ls="clr-namespace:ls;assembly=SharedGUI"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    mc:Ignorable="d">

    <ResourceDictionary x:Key="SideBoxesDoubleResources">
        <System:Double x:Key="MaxWrapPanelWidth">700</System:Double>
    </ResourceDictionary>
    <ResourceDictionary x:Key="SideBoxesTripleResources">
        <System:Double x:Key="MaxWrapPanelWidth">1100</System:Double>
    </ResourceDictionary>

    <ls:LSTooltip x:Key="CCSpellRefTooltip" Content="{Binding Path=DataContext.Spell, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
    

    <Style x:Key="StepButtonFiller" TargetType="Image">
        <Setter Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_fillers.png"/>
        <Setter Property="Stretch" Value="None"/>
    </Style>

    <ControlTemplate x:Key="StepButton" TargetType="ls:LSRadioButton">
        <Grid>
            <Image x:Name="img" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_d.png" Stretch="None"/>
            <Image Source="{DynamicResource Icon}" Stretch="None" VerticalAlignment="Top" Margin="3,16,-3,0"/>

            <StackPanel x:Name="content" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="-10,0,10,36">
                <Image x:Name="invalid" Visibility="Hidden" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/indicator_checkFail.png" Stretch="None" VerticalAlignment="Center" Margin="-10,0,10,0"/>
                <TextBlock x:Name="label" Text="{Binding Content, RelativeSource={RelativeSource Mode=TemplatedParent}}" Background="{x:Null}" VerticalAlignment="Center" MaxHeight="66"/>
            </StackPanel>
        </Grid>

        <ControlTemplate.Triggers>
            <!-- Not active -->
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_d.png"/>
                <Setter TargetName="label" Property="Foreground" Value="{DynamicResource LS_InactivePanelFontColor}"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="False"/>
                    <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_h.png"/>
                </MultiTrigger.Setters>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="False"/>
                    <Condition Property="IsPressed" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_p.png"/>
                    <Setter TargetName="content" Property="Margin" Value="-10,4,10,32" />
                </MultiTrigger.Setters>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="False"/>
                    <Condition Property="IsEnabled" Value="False"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_disabled.png"/>
                </MultiTrigger.Setters>
            </MultiTrigger>

            <!-- active -->
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_h.png"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True"/>
                    <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_h.png"/>
                </MultiTrigger.Setters>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True"/>
                    <Condition Property="IsPressed" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_p.png"/>
                    <Setter TargetName="content" Property="Margin" Value="-10,4,10,32" />
                </MultiTrigger.Setters>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True"/>
                    <Condition Property="IsEnabled" Value="False"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter TargetName="img" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_inactive_disabled.png"/>
                </MultiTrigger.Setters>
            </MultiTrigger>

            <!-- button label -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="label" Property="Foreground" Value="{DynamicResource LS_ActivePanelFontColor}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="label" Property="Foreground" Value="{DynamicResource LS_ActivePanelFontColor}"/>
            </Trigger>

            <Trigger Property="Tag" Value="True">
                <Setter TargetName="invalid" Property="Visibility" Value="Visible"/>
            </Trigger>

        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="NavButton" TargetType="ls:LSButton">
        <ControlTemplate.Resources>
            <ImageSource x:Key="ButtonNormal">pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_prevNext_d.png</ImageSource>
            <ImageSource x:Key="ButtonHighlight">pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_prevNext_h.png</ImageSource>
            <ImageSource x:Key="ButtonPressed">pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_prevNext_p.png</ImageSource>
            <ImageSource x:Key="ButtonDisabled">pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/topNav_prevNext_disabled.png</ImageSource>
        </ControlTemplate.Resources>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Grid>
                <Image x:Name="img" Source="{DynamicResource ButtonNormal}" Stretch="None"/>
                <Image x:Name="icon" Source="{DynamicResource Icon}" Stretch="None"/>
            </Grid>
        </StackPanel>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="img" Property="Source" Value="{DynamicResource ButtonHighlight}"/>
                <Setter TargetName="icon" Property="Source" Value="{DynamicResource IconHighlight}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="img" Property="Source" Value="{DynamicResource ButtonPressed}"/>
                <Setter TargetName="icon" Property="Margin" Value="0,4,0,-4"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="img" Property="Source" Value="{DynamicResource ButtonDisabled}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="BottomItemTextStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{DynamicResource LargeFontSize}"/>
    </Style>

    <DataTemplate x:Key="CharacterCardAbilityTemplate">
        <StackPanel x:Name="Header" ToolTip="{StaticResource ManagedTooltip}" ToolTipService.Placement="Left">
            <Grid>
                <Image x:Name="frame" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ability_frame_01.png" Stretch="None"/>
                <TextBlock Text="{Binding ShortDisplayName}" Foreground="{DynamicResource LS_ActivePanelFontColor}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,74,0,0"/>
            </Grid>
            <TextBlock Text="{Binding Value}" FontSize="{DynamicResource IntermediateFontSize}" TextAlignment="Center" Margin="0,-20,0,0"/>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsPrimary}" Value="True">
                <Setter TargetName="frame" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ability_frame_02.png"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <ControlTemplate x:Key="CharacterCardTemplate">
        <ControlTemplate.Resources>
            <Style x:Key="SpellSelectorItemControlStyle" TargetType="ItemsControl">
                <Setter Property="ItemsControl.ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="550"/>
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemsControl.ItemTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <Grid x:Name="holder" ToolTip="{StaticResource CCSpellRefTooltip}" DataContext="{Binding Spell}" Margin="-10,0,-10,0">
                                <Rectangle Width="80" Height="80" Fill="{Binding Icon}"/>
                                <TextBlock Text="{Binding Level, Converter={StaticResource DecimalToRomanConverter}}" Margin="0,0,20,15" Foreground="{StaticResource LS_specialTxtColor}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Height="35" FontSize="32" FontWeight="Bold" noesis:Text.Stroke="#FF000000" noesis:Text.StrokeThickness="5"/>
                                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None" Margin="10,10,0,0"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Spell}" Value="{x:Null}">
                                    <Setter TargetName="holder" Property="ToolTipService.IsEnabled" Value="False"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ControlTemplate.Resources>

        <Grid>
            <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/characterCard_bg.png" Stretch="None" VerticalAlignment="Top" Margin="0,0,0,46"/>

            <StackPanel Margin="0,32,0,0">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                        <Setter Property="FontSize" Value="{DynamicResource LargeFontSize}"/>
                        <Setter Property="LineHeight" Value="{DynamicResource MassiveFontSize}"/>
                    </Style>
                </StackPanel.Resources>

                <Image DataContext="{Binding DummyCharacter.stats.ClassList[0]}" Style="{DynamicResource MainClassIconStyle}" Margin="0,0,0,-16"/>

                <TextBlock x:Name="nameText" Text="{Binding DummyCharacter.Name}" MaxWidth="600" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>

                <StackPanel Margin="0,10,0,0">

                    <DockPanel Width="500">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Source='hadf27237ge191g4922ga84cg055b984c9b1f', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}"/>
                        <TextBlock Text="{Binding DummyCharacter.Stats.Race}" TextWrapping="Wrap" TextAlignment="Right" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                    </DockPanel>

                    <DockPanel Width="500">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Source='h4d0d00cfg4edeg42c3gaa4agcc3908351b8d', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}"/>
                        <TextBlock Text="{Binding DummyCharacter.Stats.ClassList[0].ClassDisplayName}" TextWrapping="Wrap" TextAlignment="Right" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                    </DockPanel>

                    <DockPanel Visibility="{Binding DummyCharacter.Stats.ClassList[0].SubclassDisplayName, Converter={StaticResource StringToVisibilityConverter}}" Width="500">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Source='h1e67bc9cg0f53g4218g8ce8geb6a6636f141', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}"/>
                        <TextBlock Text="{Binding DummyCharacter.Stats.ClassList[0].SubclassDisplayName}" TextWrapping="Wrap" TextAlignment="Right" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                    </DockPanel>

                    <DockPanel Visibility="{Binding DummyCharacter.Stats.God, Converter={StaticResource StringToVisibilityConverter}}" Width="500">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Source='h5238a9c6gb90fg40bbg9335gfb37d6e91b94', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}"/>
                        <TextBlock Text="{Binding DummyCharacter.Stats.God}" TextWrapping="Wrap" TextAlignment="Right" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                    </DockPanel>                    
                    
                </StackPanel>


                <TextBlock Text="{Binding Source='h3a6a5b07g266eg4391ga17bg9975ccbe59c4', Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center" Foreground="{DynamicResource LS_PrimaryColor}" Margin="0,40,0,-30"/>
                <ItemsControl DataContext="{Binding DummyCharacter}" ItemsSource="{Binding Stats.Abilities}" ItemTemplate="{StaticResource CharacterCardAbilityTemplate}" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="600"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock x:Name="proficenciesTitle" Visibility="{Binding DummyCharacter.Stats.ProficientSkills.Count, Converter={StaticResource CountToVisibilityConverter}}" Text="{Binding Source='hbdc95889g6f3fg46efg9993g036cf077a0e7', Converter={StaticResource TranslatedStringConverter}}" 
                            HorizontalAlignment="Center" Foreground="{DynamicResource LS_PrimaryColor}" Margin="0,40,0,-10"/>
                <ItemsControl ItemsSource="{Binding DummyCharacter.Stats.ProficientSkills}" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" ToolTip="{StaticResource ManagedTooltip}" HorizontalAlignment="Center" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="expertiseTitle" Visibility="{Binding DummyCharacter.Stats.ExpertSkills.Count, Converter={StaticResource CountToVisibilityConverter}}" Text="{Binding Source='h49b6ffe7g11f4g403dg85a0gde8b71a19b2d', Converter={StaticResource TranslatedStringConverter}}" 
                            HorizontalAlignment="Center" Foreground="{DynamicResource LS_PrimaryColor}" Margin="0,40,0,-10"/>
                <ItemsControl ItemsSource="{Binding DummyCharacter.Stats.ExpertSkills}" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" ToolTip="{StaticResource ManagedTooltip}" HorizontalAlignment="Center" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,20,0,0" Visibility="{Binding ProgressionCantrips.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock Text="{Binding Source='h7d02199dg44ecg4a1egbcacg9cc1cec197b3', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource LargeFontSize}" HorizontalAlignment="Center"/>
                    <Grid HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/decorated_box.png" Stretch="None"/>
                        <ItemsControl Style="{StaticResource SpellSelectorItemControlStyle}" ItemsSource="{Binding ProgressionCantrips}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,20,0,0" Visibility="{Binding ProgressionSpells.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock Text="{Binding Source='h2975f9c0gc2aag47d9ga3b3g3dd5171b9bf4', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource LargeFontSize}" HorizontalAlignment="Center"/>
                    <Grid HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/decorated_box.png" Stretch="None"/>
                        <ItemsControl Style="{StaticResource SpellSelectorItemControlStyle}" ItemsSource="{Binding ProgressionSpells}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Replacement Spells-->
                <StackPanel Visibility="{Binding ClassProgressionDetails.InSpellReplacement, Converter={StaticResource NullToCollapsedConverter}}" Margin="0,20,0,0">
                    <TextBlock Text="{Binding Source='h883d6c23g0e9cg4775g8d77gdaf9c48abcd6', Converter={StaticResource TranslatedStringConverter}}" Foreground="{DynamicResource LS_PrimaryColor}" HorizontalAlignment="Center"/>

                    <Grid x:Name="replacementSpellHolder"  DataContext="{Binding ClassProgressionDetails.InSpellReplacement}" HorizontalAlignment="Center" Margin="-10,10,-10,0" ToolTipService.IsEnabled="{Binding Spell , Converter={StaticResource NullToBoolFalseConverter}}">
                        <Grid.ToolTip>
                            <ls:LSTooltip Content="{Binding Path=DataContext.Spell, ElementName=replacementSpellHolder}"/>
                        </Grid.ToolTip>
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/decorated_box.png" Stretch="None"/>

                        <Rectangle Width="80" Height="80" Fill="{Binding Spell.Icon}"/>
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None" Margin="10,10,0,0"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </Grid>
        
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding CanEditName}" Value="False">
                <Setter TargetName="nameText" Property="Text" Value="{Binding OriginCharacters.SelectedItem.Name}"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <ControlTemplate x:Key="AbilityText">
        <TextBlock Foreground="{DynamicResource LS_PrimaryColor}">
            <Run Text="{Binding Name}"/>
            <Run x:Name="AbilitySuffix" Text="{Binding Value, StringFormat={}{0: +#; -#; +0}}"/>
        </TextBlock>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding IsValueInName}" Value="True">
                <Setter TargetName="AbilitySuffix" Property="Text" Value=""/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="BoxedItemSelection">
        <ControlTemplate.Resources>
            <System:Double x:Key="MaxWrapPanelWidth">800</System:Double>
        </ControlTemplate.Resources>

        <ls:LSComboBox ItemsSource="{Binding ComboItems}" SelectedItem="{Binding SelectedItem}" HorizontalAlignment="Center" Background="Transparent" BorderThickness="0">
            <ls:LSComboBox.Template>
                <ControlTemplate>
                    <ItemsPresenter  />
                </ControlTemplate>
            </ls:LSComboBox.Template>
            <ls:LSComboBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel MaxWidth="{DynamicResource MaxWrapPanelWidth}"/>
                </ItemsPanelTemplate>
            </ls:LSComboBox.ItemsPanel>

            <ls:LSComboBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid x:Name="root" ToolTipService.ShowOnDisabled="True" ToolTipService.IsEnabled="False">
                                    <Grid.ToolTip>
                                        <ls:LSTooltip >
                                            <TextBlock Text="{Binding Path=DataContext.DisabledReason, ElementName=root}"/>
                                        </ls:LSTooltip>
                                    </Grid.ToolTip>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="img01" Grid.Column="0" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_d_01.png" Stretch="None"/>
                                        <Grid x:Name="g02" Grid.Column="1">
                                            <Grid.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_d_02.png" Stretch="Fill" TileMode="Tile"/>
                                            </Grid.Background>
                                        </Grid>
                                        <Image x:Name="img03" Grid.Column="2" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_d_03.png" Stretch="None"/>
                                        <Grid x:Name="g04" Grid.Column="3">
                                            <Grid.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_d_04.png" Stretch="Fill" TileMode="Tile"/>
                                            </Grid.Background>
                                        </Grid>
                                        <Image x:Name="img05" Grid.Column="4" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_d_05.png" Stretch="None"/>
                                    </Grid>
                                    <TextBlock x:Name="txt" Text="{Binding Name}" Style="{StaticResource BottomItemTextStyle}" Foreground="{DynamicResource LS_InfoColor4}" Margin="30,0,30,0"/>


                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="MouseEnter">
                                            <ls:LSPlaySound Sound="{DynamicResource SoundEventHover}"/>
                                        </b:EventTrigger>

                                        <b:EventTrigger EventName="MouseDown">
                                            <ls:LSPlaySound Sound="{DynamicResource SoundEventPress}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter TargetName="root" Property="ToolTipService.IsEnabled" Value="True"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="img01" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_h_01.png"/>
                                        <Setter TargetName="g02" Property="Background">
                                            <Setter.Value>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_h_02.png" Stretch="Fill" TileMode="Tile"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="img03" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_h_03.png"/>
                                        <Setter TargetName="g04" Property="Background">
                                            <Setter.Value>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_h_04.png" Stretch="Fill" TileMode="Tile"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="img05" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_default_h_05.png"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="img01" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_d_01.png"/>
                                        <Setter TargetName="g02" Property="Background">
                                            <Setter.Value>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_d_02.png" Stretch="Fill" TileMode="Tile"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="img03" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_d_03.png"/>
                                        <Setter TargetName="g04" Property="Background">
                                            <Setter.Value>
                                                <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_d_04.png" Stretch="Fill" TileMode="Tile"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="img05" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_d_05.png"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource LS_InfoColor1}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.Setters>
                                            <Setter TargetName="img01" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_h_01.png"/>
                                            <Setter TargetName="g02" Property="Background">
                                                <Setter.Value>
                                                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_h_02.png" Stretch="Fill" TileMode="Tile"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="img03" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_h_03.png"/>
                                            <Setter TargetName="g04" Property="Background">
                                                <Setter.Value>
                                                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_h_04.png" Stretch="Fill" TileMode="Tile"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="img05" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selection_active_h_05.png"/>
                                        </MultiTrigger.Setters>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ls:LSComboBox.ItemContainerStyle>

        </ls:LSComboBox>
    </ControlTemplate>

    <Style x:Key="PanelTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource TitleFontSize}"/>
        <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>

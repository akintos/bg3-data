    <ControlTemplate x:Key="CharacterClassFeatures">
        <StackPanel x:Name="classFeatures" HorizontalAlignment="Center">

            <b:Interaction.Behaviors>
                <noesis:CollectionFilterBehavior ItemsSource="{Binding ClassProgressionDetails.Progressions}" Predicate="{Binding IsNotSubProgressionPredicate}"/>
                <noesis:CollectionFilterBehavior ItemsSource="{Binding ClassProgressionDetails.Progressions}" Predicate="{Binding IsSubProgressionPredicate}"/>
            </b:Interaction.Behaviors>

            <TextBlock Text="{Binding Source='hc1d70a06g88a4g4ce6g8dc0ge2c17c5f0eb2', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource PanelHeaderText}"/>

            <!-- Class Progressions -->
            <ItemsControl ItemTemplate="{DynamicResource ProgressionFeaturesTemplate}" ItemsSource="{Binding (b:Interaction.Behaviors)[0].FilteredItems, ElementName=classFeatures}"/>

            <!-- Class Ability Bonus selector-->
            <Grid Visibility="{Binding ClassProgressionDetails.AbilitySelection.Count, Converter={StaticResource CountToVisibilityConverter}}" HorizontalAlignment="Center" Margin="0,16,0,0">
                <ContentControl Template="{StaticResource ValidationFailedHighlighter}" Tag="{Binding ClassAbilityInvalid}">
                    <ContentControl Template="{StaticResource AbilitiesImprovementTemplate}" DataContext="{Binding ClassProgressionDetails}">
                        <Grid>
                            <TextBlock Foreground="{DynamicResource LS_PrimaryColor}" VerticalAlignment="Center" Margin="52,4,0,0">
                                <Run Text="{Binding Source='h4d0d00cfg4edeg42c3gaa4agcc3908351b8d', Converter={StaticResource TranslatedStringConverter}, StringFormat='{}{0}: '}" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                                <Run Text="{Binding Source='h669868dfg9ce9g47b8ga23dgb0302547b457', Converter={StaticResource TranslatedStringConverter}}"/>
                                <Run Text="{Binding SelectedAbilityCount, StringFormat=' ({0}'}"/><Run Text="{Binding MaxSelectedAbilityCount, StringFormat='/{0})'}"/>
                            </TextBlock>
                        </Grid>
                    </ContentControl>
                </ContentControl>
            </Grid>

            <!-- Sub Class Progressions -->
            <TextBlock Text="{Binding Source='ha3fe9fd2gcd03g4e0bgbb45gf60144f6aba6', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource PanelHeaderText}" Visibility="{Binding HasSubClassProgressions, Converter={StaticResource BoolToVisibleConverter}}" />
            <ItemsControl ItemTemplate="{DynamicResource ProgressionFeaturesTemplate}" ItemsSource="{Binding (b:Interaction.Behaviors)[1].FilteredItems, ElementName=classFeatures}"/>
            
        </StackPanel>
    </ControlTemplate>


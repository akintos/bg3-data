            </Grid>
            <TextBlock x:Name="text" Text="{Binding Name}" ToolTipService.Placement="Left" Foreground="{DynamicResource LS_ActivePanelFontColor}" HorizontalAlignment="Left" Margin="100,4,0,0">
                <TextBlock.ToolTip>
                    <ls:LSTooltip Content="{Binding Path=DataContext, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                </TextBlock.ToolTip>
            </TextBlock>
            <TextBlock x:Name="source" Visibility="Collapsed" HorizontalAlignment="Right" Foreground="{DynamicResource LS_InactivePanelFontColor}" Margin="0,0,40,0"/>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="text" Property="Foreground" Value="{DynamicResource LS_ActivePanelFontColor}"/>
            </Trigger>
            <DataTrigger Binding="{Binding Value}" Value="1.0">
                <Setter TargetName="box" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/checkHolder_skills_selected.png"/>
                <Setter TargetName="check" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/checkMark_skills_selected.png"/>
                <Setter TargetName="text" Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Enabled}" Value="False">
                <Setter TargetName="box" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/checkHolder_skills_disabled.png"/>
                <Setter TargetName="check" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/checkMark_skills_selectedBefore.png"/>
                <Setter TargetName="text" Property="Foreground" Value="{DynamicResource LS_InactivePanelFontColor}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Value}" Value="1.0"/>
                    <Condition Binding="{Binding Enabled}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="source" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding SkillSource}" Value="Background">
                <Setter TargetName="source" Property="Text" Value="{Binding Source='hedd9548eg9694g41d4g85a5gcca6ecdfdea8', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SkillSource}" Value="Race">
                <Setter TargetName="source" Property="Text" Value="{Binding Source='h2b695f65g9317g4a75g9ae2g7f45350c3bfc', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger> 
            <DataTrigger Binding="{Binding SkillSource}" Value="Class">
                <Setter TargetName="source" Property="Text" Value="{Binding Source='h4f84523ag0b42g41f8gafcfgb25f74fd1b74', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SkillSource}" Value="RaceSelector">
                <Setter TargetName="source" Property="Text" Value="{Binding Source='h243c9397g8fbbg4ba5gacd6gc49ca5826bf0', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SkillSource}" Value="ClassSelector">
                <Setter TargetName="source" Property="Text" Value="{Binding Source='h6d9d386dgb1f5g423fg94cfg7776d102b906', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>            
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SkillSelectionBox" TargetType="ContentControl">
        <StackPanel Margin="0,20,0,20" Visibility="{Binding MaxSelectedSkillCount, Converter={StaticResource CountToVisibilityConverter}}">
            <ContentControl Template="{DynamicResource Header}" VerticalAlignment="Center"/>
            <ContentControl Template="{StaticResource ValidationFailedHighlighter}" Tag="{Binding IsInvalid}" HorizontalAlignment="Left" Margin="70,0,0,0">
                <ContentControl Template="{DynamicResource SelectSkills}" DataContext="{Binding Skills}"/>
            </ContentControl>
        </StackPanel>
    </ControlTemplate>

	<Style x:Key="SpellOverrideBorder" TargetType="Border">
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="4"/>
	</Style>
	
    <ControlTemplate x:Key="ShowSpellsTemplate" TargetType="ContentControl">
        <StackPanel Visibility="{Binding Count, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource Mode=TemplatedParent}}" HorizontalAlignment="Center" FontSize="{DynamicResource BigFontSize}" Margin="0,24,0,0"/>

			<ContentControl Template="{StaticResource CharacterCreationDecoratedBoxPanel}">

                <ItemsControl ItemsSource="{Binding}" HorizontalAlignment="Center" Margin="0,18,0,18">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="688"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
							<Border x:Name="border" Style="{StaticResource SpellOverrideBorder}" VerticalAlignment="Center">
                                <Grid ToolTip="{StaticResource ManagedTooltip}" ToolTipService.Placement="Left">
									<Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None"  Margin="0,0,-10,-10"/>
									<Grid Background="{Binding Icon}" Width="80" Height="80"/>
                                    <TextBlock Text="{Binding Level, Converter={StaticResource DecimalToRomanConverter}}" Margin="0,0,8,4" Foreground="{StaticResource LS_specialTxtColor}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Height="35" FontSize="32" FontWeight="Bold" noesis:Text.Stroke="#FF000000" noesis:Text.StrokeThickness="5"/>
                                    <Image x:Name="selected" Visibility="Collapsed" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selector_spellslot.png" Stretch="None"/>
                                </Grid>
							</Border>
							<DataTemplate.Triggers>
								<DataTrigger Binding="{Binding Override}" Value="Worse">
									<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideWorse}"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding Override}" Value="Equal">
									<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideEqual}"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding Override}" Value="Better">
									<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideBetter}"/>
								</DataTrigger>
								<DataTrigger Binding="{Binding Override}" Value="Different">
									<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideDifferent}"/>
								</DataTrigger>
							</DataTemplate.Triggers>
						</DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

			</ContentControl>
        </StackPanel>
    </ControlTemplate>

    <ControlTemplate x:Key="SpellsChosen">
        <ItemsControl ItemsSource="{Binding}" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel MaxWidth="500"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="-10,0,0,0"  ToolTipService.IsEnabled="{Binding Spell,Converter={StaticResource NullToBoolFalseConverter}}" ToolTip="{StaticResource CCSpellRefTooltip}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseLeftButtonUp" >
                                <b:InvokeCommandAction 
                                    Command="{Binding DataContext.OpenSpellSelector, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                                    CommandParameter="{Binding ElementName=chosenSpellsSection, Path=DataContext}"/>

                                <b:InvokeCommandAction 
                                    Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                                    CommandParameter="UI_HUD_CC_Spells_Release"/>
                            </b:EventTrigger>

                            <b:EventTrigger EventName="MouseEnter">
                                <b:InvokeCommandAction 
                                    Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                                    CommandParameter="UI_Shared_Hover"/>
                            </b:EventTrigger>

                            <b:EventTrigger EventName="MouseLeave">
                                <b:InvokeCommandAction 
                                    Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                                    CommandParameter="UI_Shared_Out"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                        <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None" Margin="10,10,0,0"/>
                        <Grid Background="{Binding Spell.Icon}" Width="80" Height="80"/>
                        <Image x:Name="selected" Visibility="Collapsed" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/selector_spellslot.png" Stretch="None"/>
                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Visibility" Value="Visible" TargetName="selected"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ControlTemplate>

    <ControlTemplate x:Key="SpellReplacement">
        <Grid x:Name="holder" ToolTip="{StaticResource CCSpellRefTooltip}" Margin="-10,0,-10,0">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="MouseLeftButtonUp" >
                    <b:InvokeCommandAction 
                        Command="{Binding DataContext.OpenSpellReplacer, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                        CommandParameter="{Binding ElementName=chosenSpellsSection, Path=DataContext}"/>

                    <b:InvokeCommandAction 
                        Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                        CommandParameter="UI_HUD_CC_Spells_Release"/>
                </b:EventTrigger>

                <b:EventTrigger EventName="MouseEnter">
                    <b:InvokeCommandAction 
                        Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                        CommandParameter="UI_Shared_Hover"/>
                </b:EventTrigger>

                <b:EventTrigger EventName="MouseLeave">
                    <b:InvokeCommandAction 
                        Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" 
                        CommandParameter="UI_Shared_Out"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <Grid>
                <Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None" Margin="10,10,0,0"/>
                <Rectangle Fill="{Binding Spell.Icon}" Width="80" Height="80"/>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding Spell}" Value="{x:Null}">
                <Setter TargetName="holder" Property="ToolTipService.IsEnabled" Value="False"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <ControlTemplate x:Key="SpellSelectorAdditionsTemplate">
        <StackPanel x:Name="chosenSpellsSection" HorizontalAlignment="Center" VerticalAlignment="Top">
            <ContentControl Template="{DynamicResource Title}"/>

            <ContentControl Template="{StaticResource ValidationFailedHighlighter}" Tag="{Binding IsInvalid}">
                <Grid HorizontalAlignment="Center">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseLeftButtonUp" >
                            <b:InvokeCommandAction Command="{Binding DataContext.OpenSpellSelector, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding ElementName=chosenSpellsSection, Path=DataContext}"/>
                            <b:InvokeCommandAction Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="UI_HUD_CC_Spells_Release"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <StackPanel>

                        <ItemsControl ItemsSource="{Binding Additions}" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel MaxWidth="784"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
									<Border x:Name="border" Style="{StaticResource SpellOverrideBorder}">
                                        <Grid x:Name="holder" ToolTip="{StaticResource CCSpellRefTooltip}"  ToolTipService.IsEnabled="{Binding Spell,Converter={StaticResource NullToBoolFalseConverter}}" ToolTipService.Placement="Left">
											<Image Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellslot.png" Stretch="None" Margin="0,0,-10,-10"/>
											<Rectangle Width="80" Height="80" Fill="{Binding Spell.Icon}"/>
                                            <TextBlock Text="{Binding Spell.Level, Converter={StaticResource DecimalToRomanConverter}}" Margin="0,0,10,5" Foreground="{StaticResource LS_specialTxtColor}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Height="35" FontSize="32" FontWeight="Bold" noesis:Text.Stroke="#FF000000" noesis:Text.StrokeThickness="5"/>
											<b:Interaction.Triggers>
												<b:EventTrigger EventName="MouseEnter">
													<b:InvokeCommandAction Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="UI_Shared_Hover"/>
												</b:EventTrigger>
												<b:EventTrigger EventName="MouseLeave">
													<b:InvokeCommandAction Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="UI_Shared_Out"/>
												</b:EventTrigger>
											</b:Interaction.Triggers>
										</Grid>
									</Border>
									<DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Spell}" Value="{x:Null}">
                                            <Setter TargetName="holder" Property="ToolTipService.IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Spell.Override}" Value="Worse">
											<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideWorse}"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Spell.Override}" Value="Equal">
											<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideEqual}"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Spell.Override}" Value="Better">
											<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideBetter}"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding Spell.Override}" Value="Different">
											<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LS_SpellOverrideDifferent}"/>
										</DataTrigger>
									</DataTemplate.Triggers>
								</DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Grid>
            </ContentControl>
        </StackPanel>
    </ControlTemplate>

    <ControlTemplate x:Key="SpellsReplacedTemplate">
        <StackPanel x:Name="chosenSpellsSection" HorizontalAlignment="Center">
            <ContentControl Template="{DynamicResource Title}"/>
            <ContentControl Template="{StaticResource SpellReplacement}" DataContext="{Binding InSpellReplacement}"/>
        </StackPanel>
    </ControlTemplate>

    <ControlTemplate x:Key="SpellPopupInnerFrame" TargetType="Control">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top">
                <Image DockPanel.Dock="Left" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_01.png" Stretch="None"/>
                <Image DockPanel.Dock="Right" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_03.png" Stretch="None"/>
                <Grid>
                    <Grid.Background>
                        <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_02.png" Stretch="Fill" TileMode="Tile"/>
                    </Grid.Background>
                </Grid>
            </DockPanel>
            <DockPanel DockPanel.Dock="Bottom">
                <Image DockPanel.Dock="Left" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_07.png" Stretch="None"/>
                <Image DockPanel.Dock="Right" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_09.png" Stretch="None"/>
                <Grid>
                    <Grid.Background>
                        <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_08.png" Stretch="Fill" TileMode="Tile"/>
                    </Grid.Background>
                </Grid>
            </DockPanel>
            <Grid DockPanel.Dock="Left" Width="44" HorizontalAlignment="Left">
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_04.png" Stretch="Fill" TileMode="Tile"/>
                </Grid.Background>
            </Grid>
            <Grid DockPanel.Dock="Right" Width="44" HorizontalAlignment="Right">
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_06.png" Stretch="Fill" TileMode="Tile"/>
                </Grid.Background>
            </Grid>
            <Grid>
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/popover_spells_subFrame_05.png" Stretch="Fill" TileMode="Tile"/>
                </Grid.Background>
            </Grid>
        </DockPanel>
    </ControlTemplate>    
    
    <ControlTemplate x:Key="SpellRemover">
        <Grid Background="Transparent">
            <Image x:Name="remover" Visibility="Hidden" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/remover_spellslot.png" Stretch="None"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Visibility" Value="Visible" TargetName="remover"/>
            </Trigger>
            <DataTrigger Binding="{Binding Spell}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" TargetName="remover"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SpellBox" TargetType="Control">
        <DockPanel HorizontalAlignment="Center">
            <Image DockPanel.Dock="Top" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellbox_top.png" Stretch="None"/>
            <Image DockPanel.Dock="Bottom" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellbox_bottom.png" Stretch="None"/>
            <Grid>
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/spellbox_middle.png" TileMode="Tile"/>
                </Grid.Background>
            </Grid>
        </DockPanel>
    </ControlTemplate>

    <ControlTemplate x:Key="FeatExpanderToggleButton" TargetType="{x:Type ToggleButton}">
        <Grid Background="Transparent">
            <ContentPresenter/>
            <Path Name="Arrow" Width="40" Data="M 0 0 L 8 8 L 16 0 Z" Fill="{DynamicResource LS_PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="true">
                <Setter TargetName="Arrow" Property="Data" Value="M 0 8 L 8 0 L 16 8 Z"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="FeatExpanderStyle" TargetType="{x:Type Expander}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Expander}">
                    <DockPanel>
                        <ToggleButton DockPanel.Dock="Top" x:Name="ExpanderButton" Template="{StaticResource FeatExpanderToggleButton}"  IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Content>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton.Content>
                        </ToggleButton>
                        <ContentPresenter Grid.Row="1" Name="Content"/>
                    </DockPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="Content" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger SourceName="ExpanderButton" Property="IsChecked" Value="True">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="FeatIndicator" TargetType="ls:LSRadioButton">
        <Grid>
            <Image x:Name="bg" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/btn_small_round_d.png" Stretch="None"/>
            <Image x:Name="icon" Visibility="Collapsed" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/ico_tick_active_d.png" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/btn_small_round_h.png"/>
                <Setter TargetName="icon" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/ico_tick_active_h.png"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bg" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/btn_small_round_p.png"/>
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAlreadyTaken}" Value="True">
                <Setter TargetName="bg" Property="Visibility" Value="Hidden"/>
                <Setter TargetName="icon" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/Buttons/ico_tick_inactive_d.png"/>
                <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRequirementsMet}" Value="False">
                <Setter TargetName="bg" Property="Visibility" Value="Hidden"/>
                <Setter TargetName="icon" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterLevelup/ico_locked.png"/>
                <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

</ResourceDictionary>
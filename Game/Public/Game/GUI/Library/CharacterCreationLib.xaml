    <ControlTemplate x:Key="AbilityAdjusterTemplate">
        <ls:LSToggleButton SoundID="UI_HUD_CC_AbilityExpander" Margin="0,20,0,20">
            <ls:LSToggleButton.Template>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <StackPanel HorizontalAlignment="Stretch" Background="Transparent">
                        <Grid x:Name="header" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" x:Name="button" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ability_toggle_d.png" Stretch="None">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Skills.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <Image Grid.Column="1" Style="{DynamicResource AbilityIconStyle}" VerticalAlignment="Center"/>
                            <Image Grid.Column="2" HorizontalAlignment="Center" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ico_proficiency.png" Stretch="None" Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibleConverter}, ConverterParameter='True'}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Name}" ToolTipService.Placement="Left" FontSize="{DynamicResource BigFontSize}" VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ls:LSTooltip Content="{Binding Path=DataContext, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBlock Grid.Column="4" Text="{Binding Modifier, StringFormat={}{0:+#;-#;+0}}" Foreground="{DynamicResource LS_ActivePanelFontColor}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{Binding Value}" Foreground="{DynamicResource LS_PrimaryColor}" FontSize="{DynamicResource BigFontSize}" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="6" Orientation="Horizontal">
                                <ls:LSButton x:Name="inc" Template="{StaticResource AbilityPlusButtonTemplate}" Command="{Binding DataContext.IncreaseAbility, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding}" SoundID="UI_HUD_CC_IncreaseAbility"/>
                                <ls:LSButton x:Name="dec" Template="{StaticResource AbilityMinusButtonTemplate}" Command="{Binding DataContext.DecreaseAbility, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding}" SoundID="UI_HUD_CC_DecreaseAbility"/>
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="Content" Margin="208,-50,0,0">
                            <ItemsControl ItemsSource="{Binding Skills}" Visibility="{Binding Skills.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTipService.Placement="Left">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="400"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.ToolTip>
                                                <ls:LSTooltip Content="{Binding Path=DataContext, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                                            </Grid.ToolTip>

                                            <Image Grid.Column="0" x:Name="bullet" Visibility="Collapsed" Source="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ico_bullet.png" Stretch="None" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" x:Name="name" Text="{Binding Name}" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                                            <TextBlock Grid.Column="2" x:Name="value" Text="{Binding Value, StringFormat={}{0:+#;-#;+0}}" Foreground="{DynamicResource LS_ActivePanelFontColor}"/>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsProficient}" Value="True">
                                                <Setter TargetName="bullet" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsExpert}" Value="True">
                                                <Setter TargetName="bullet" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="button" Property="Source" Value="pack://application:,,,/GustavNoesisGUI;component/Assets/CharacterCreation/ability_toggle_h.png"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="Content" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="button" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleY="-1" CenterY="12"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ls:LSToggleButton.Template>
        </ls:LSToggleButton>
    </ControlTemplate>


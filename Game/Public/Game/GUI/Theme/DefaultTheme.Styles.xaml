                    </RepeatButton.Template>
                </ls:LSRepeatButton>
            </Grid>

            <TickBar x:Name="BottomTick" SnapsToDevicePixels="True" Fill="{TemplateBinding Foreground}" Placement="Bottom" Height="4" Visibility="Collapsed" />

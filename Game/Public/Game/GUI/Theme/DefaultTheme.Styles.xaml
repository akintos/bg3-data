                                        <ls:LSRepeatButton x:Name="IncreaseBtn" Command="ScrollBar.PageRightCommand" Style="{StaticResource ScrollBarPageButton}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
